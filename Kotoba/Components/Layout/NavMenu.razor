@using Kotoba.Modules.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<div class="sidebar-shell">
    <div class="brand" title="Kotoba">🍋</div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="nav-column" aria-label="Primary">
            @if (CurrentUserProfile?.AccountStatus != AccountStatus.Deactivated)
            {
                <NavLink class="nav-btn" href="" Match="NavLinkMatch.All" title="Home">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M3 11.5 12 4l9 7.5" />
                        <path d="M6 10.5V20h12v-9.5" />
                    </svg>
                    <span class="sr-only">Home</span>
                </NavLink>
            }

            <AuthorizeView>
                <Authorized>
                    <NavLink class="nav-btn" href="chat" title="Chat">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                            <path d="M8 9h8" />
                            <path d="M8 13h5" />
                        </svg>
                        <span class="sr-only">Chat</span>
                    </NavLink>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <NavLink class="nav-btn" href="profile" title="Profile">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 3.5-6 8-6s8 2 8 6" />
                        </svg>
                        <span class="sr-only">Profile</span>
                    </NavLink>
					<NavLink class="nav-btn" href="story" title="Story">
						<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="4" />
						</svg>
						<span class="sr-only">Story</span>
					</NavLink>
                    <NavLink class="nav-btn" href="notifications" title="Notifications">
                        <div style="position:relative;display:flex;align-items:center;justify-content:center;">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24"
                                 stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                <path d="M13.73 21a2 2 0 01-3.46 0" />
                            </svg>
                            @if (unreadCount > 0)
                            {
                                <div style="position:absolute;top:-6px;right:-6px;min-width:16px;height:16px;
                                    background:#c0392b;border-radius:50%;font-size:10px;font-weight:700;
                                    color:#fff;display:flex;align-items:center;justify-content:center;
                                    padding:0 3px;line-height:1;pointer-events:none;">
                                    @(unreadCount > 99 ? "99+" : unreadCount.ToString())
                                </div>
                            }
                        </div>
                        <span class="sr-only">Notifications</span>
                    </NavLink>
                </Authorized>

                <NotAuthorized>
                    <NavLink class="nav-btn" href="login" title="Login">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <path d="M10 17l5-5-5-5" />
                            <path d="M15 12H3" />
                        </svg>
                        <span class="sr-only">Login</span>
                    </NavLink>

                    <NavLink class="nav-btn" href="register" title="Register">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="8.5" cy="7" r="4" />
                            <path d="M20 8v6" />
                            <path d="M23 11h-6" />
                        </svg>
                        <span class="sr-only">Register</span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>

            <div class="nav-divider" aria-hidden="true"></div>

            <AuthorizeView>
                <Authorized>
                    @if (CurrentUserProfile?.AccountStatus != AccountStatus.Deactivated)
                    {
                        <NavLink class="nav-btn" href="settings" title="Settings">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                            <span class="sr-only">Settings</span>
                        </NavLink>
                    }
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <div class="nav-bottom">
                        <form method="post" action="/auth/logout" class="logout-form">
                            <AntiforgeryToken />
                            <button type="submit" class="nav-btn logout-button" title="Logout">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                                    <path d="M10 17l5-5-5-5" />
                                    <path d="M15 12H3" />
                                </svg>
                                <span class="sr-only">Logout</span>
                            </button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </nav>
    </div>
</div>

@code {
    [CascadingParameter] public UserProfile? CurrentUserProfile { get; set; }
    [Inject] INotificationService NotificationService { get; set; } = null!;
    [Inject] NavigationManager Navigation { get; set; } = null!;
    [Inject] IHttpContextAccessor HttpContextAccessor { get; set; } = null!;

    private int unreadCount = 0;
    private HubConnection? _hub;

    protected override async Task OnParametersSetAsync()
    {
        if (CurrentUserProfile?.UserId == null) return;
        unreadCount = await NotificationService.GetUnreadCountAsync(CurrentUserProfile.UserId);
        if (_hub == null) await StartHubAsync();
    }

    private async Task StartHubAsync()
    {
        var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
        var cookieStr = string.Join("; ", cookies?.Select(c => $"{c.Key}={c.Value}") ?? []);

        _hub = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/notificationhub"), options =>
            {
                options.Headers.Add("Cookie", cookieStr);
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<NotificationDto>("ReceiveNotification", async (_) =>
        {
            await InvokeAsync(() =>
            {
                unreadCount++;
                StateHasChanged();
            });
        });

        // Reset badge khi vào trang notifications
        Navigation.LocationChanged += OnLocationChanged;

        await _hub.StartAsync();
        await _hub.InvokeAsync("Register", CurrentUserProfile.UserId);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (e.Location.Contains("/notifications"))
        {
            unreadCount = 0;
            InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        if (_hub is not null) await _hub.DisposeAsync();
    }
}

