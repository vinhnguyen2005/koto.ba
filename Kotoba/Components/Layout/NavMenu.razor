<div class="sidebar-shell">
    <div class="brand" title="Kotoba">K</div>

    <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="nav-column" aria-label="Primary">
            <NavLink class="nav-btn" href="" Match="NavLinkMatch.All" title="Home">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M3 11.5 12 4l9 7.5" />
                    <path d="M6 10.5V20h12v-9.5" />
                </svg>
                <span class="sr-only">Home</span>
            </NavLink>

            <AuthorizeView>
                <Authorized>
                    <NavLink class="nav-btn" href="profile" title="Profile">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 3.5-6 8-6s8 2 8 6" />
                        </svg>
                        <span class="sr-only">Profile</span>
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="nav-btn" href="login" title="Login">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <path d="M10 17l5-5-5-5" />
                            <path d="M15 12H3" />
                        </svg>
                        <span class="sr-only">Login</span>
                    </NavLink>

                    <NavLink class="nav-btn" href="register" title="Register">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                            <circle cx="8.5" cy="7" r="4" />
                            <path d="M20 8v6" />
                            <path d="M23 11h-6" />
                        </svg>
                        <span class="sr-only">Register</span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>

            <div class="nav-divider" aria-hidden="true"></div>

            <NavLink class="nav-btn" href="counter" title="Counter">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <path d="M12 8v8" />
                    <path d="M8 12h8" />
                </svg>
                <span class="sr-only">Counter</span>
            </NavLink>

            <NavLink class="nav-btn" href="weather" title="Weather">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M20 17.5a4.5 4.5 0 0 0-1.9-8.6A6 6 0 0 0 6.2 9.7 3.7 3.7 0 0 0 7 17h13z" />
                </svg>
                <span class="sr-only">Weather</span>
            </NavLink>

            <AuthorizeView>
                <Authorized>
                    <div class="nav-bottom">
                        <form method="post" action="/auth/logout" class="logout-form">
                            <AntiforgeryToken />
                            <button type="submit" class="nav-btn logout-button" title="Logout">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                                    <path d="M10 17l5-5-5-5" />
                                    <path d="M15 12H3" />
                                </svg>
                                <span class="sr-only">Logout</span>
                            </button>
                        </form>
                    </div>
                </Authorized>
            </AuthorizeView>
        </nav>
    </div>
</div>

