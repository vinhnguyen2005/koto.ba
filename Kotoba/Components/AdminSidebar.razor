<aside class="admin-side">
    <div class="admin-brand">
        <div class="admin-brand-mark">K</div>
        <div>
            <div class="admin-brand-name">koto.ba</div>
            <div class="admin-brand-sub">@(IsSystemAdmin ? "System Administration" : "Business Operations")</div>
        </div>
    </div>

    @if (IsSystemAdmin)
    {
        <nav class="admin-nav" aria-label="System admin navigation">
            <p class="admin-nav-label">Overview</p>
            <a class="@GetNavItemClass(AdminSidebarItem.SystemDashboard)" href="/admin/system/dashboard">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 13h8V3H3z" />
                        <path d="M13 21h8v-8h-8z" />
                        <path d="M13 3h8v6h-8z" />
                        <path d="M3 21h8v-6H3z" />
                    </svg>
                </span>
                <span>System Overview</span>
            </a>
            <p class="admin-nav-label">Management</p>
            <a class="@GetNavItemClass(AdminSidebarItem.SystemAdminAccounts)" href="/admin/system/admins/create">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M19 8v6" />
                        <path d="M16 11h6" />
                    </svg>
                </span>
                <span>Admin Accounts</span>
            </a>
            <a class="@GetNavItemClass(AdminSidebarItem.SystemAudits)" href="/admin/system/audits">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 12h6" />
                        <path d="M9 16h6" />
                        <path d="M9 8h6" />
                        <path d="M4 5h16v14H4z" />
                    </svg>
                </span>
                <span>Audit Trails</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 2l9 4.5V12c0 5-3.4 9.6-9 10-5.6-.4-9-5-9-10V6.5z" />
                        <path d="M9 12l2 2 4-4" />
                    </svg>
                </span>
                <span>Security Alerts</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                        <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.04 1.56V21a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-1.04-1.56 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-1.56-1.04H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.65 8.9a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.7 1.7 0 0 0 1.87.34h.01A1.7 1.7 0 0 0 10 2.98V3a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1.04 1.56h.01a1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.7 1.7 0 0 0-.34 1.87v.01A1.7 1.7 0 0 0 21 10h.09a2 2 0 1 1 0 4H21a1.7 1.7 0 0 0-1.56 1z" />
                    </svg>
                </span>
                <span>Platform Settings</span>
            </a>
        </nav>
    }
    else
    {
        <nav class="admin-nav" aria-label="Business admin navigation">
            <p class="admin-nav-label">Overview</p>
            <a class="@GetNavItemClass(AdminSidebarItem.BusinessDashboard)" href="/admin/business/dashboard">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 13h8V3H3z" />
                        <path d="M13 21h8v-8h-8z" />
                        <path d="M13 3h8v6h-8z" />
                        <path d="M3 21h8v-6H3z" />
                    </svg>
                </span>
                <span>Business Overview</span>
            </a>
            <p class="admin-nav-label">Operations</p>
            <a class="@GetNavItemClass(AdminSidebarItem.BusinessUsers)" href="/admin/business/users">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </span>
                <span>Users</span>
            </a>
            <a class="@GetNavItemClass(AdminSidebarItem.BusinessAudits)" href="/admin/business/audits">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 12h6" />
                        <path d="M9 16h6" />
                        <path d="M9 8h6" />
                        <path d="M4 5h16v14H4z" />
                    </svg>
                </span>
                <span>Audit Trails</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 9v2" />
                        <path d="M12 17h.01" />
                        <path d="M10.29 3.86l-8.2 14.2A2 2 0 0 0 3.8 21h16.4a2 2 0 0 0 1.73-2.94l-8.2-14.2a2 2 0 0 0-3.44 0z" />
                    </svg>
                </span>
                <span>Reports</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <path d="M3 15h18" />
                        <path d="M9 9h.01" />
                        <path d="M15 9h.01" />
                    </svg>
                </span>
                <span>Stories</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4 19h16" />
                        <path d="M7 16V9" />
                        <path d="M12 16V5" />
                        <path d="M17 16v-3" />
                    </svg>
                </span>
                <span>Statistics</span>
            </a>
        </nav>
    }

    <div class="admin-side-footer">
        <a class="admin-nav-item admin-side-logout" href="/auth/admin/logout">
            <span class="admin-nav-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <path d="M16 17l5-5-5-5" />
                    <path d="M21 12H9" />
                </svg>
            </span>
            <span>Log out</span>
        </a>
    </div>
</aside>

@code {
    [Parameter] public bool IsSystemAdmin { get; set; }
    [Parameter] public AdminSidebarItem ActiveItem { get; set; }

    private string GetNavItemClass(AdminSidebarItem item)
    {
        return item == ActiveItem ? "admin-nav-item active" : "admin-nav-item";
    }
}
