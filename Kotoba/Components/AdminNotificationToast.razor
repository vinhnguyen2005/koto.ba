@implements IDisposable
@using Kotoba.Modules.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

@if (toasts.Count > 0)
{
    <div class="admin-toast-stack" aria-live="polite" aria-label="Admin notifications">
        @foreach (var toast in toasts)
        {
            <article class="admin-toast-card">
                <div class="admin-toast-icon" aria-hidden="true">@GetCategoryGlyph(toast.Type)</div>
                <div class="admin-toast-body">
                    <p class="admin-toast-title">@GetToastTitle(toast.Type)</p>
                    <p class="admin-toast-message">@toast.Message</p>
                    <button type="button" class="admin-toast-action" @onclick="() => OpenAction(toast)">@GetActionLabel(toast.Type)</button>
                </div>
                <button type="button" class="admin-toast-dismiss" aria-label="Dismiss" @onclick="() => Dismiss(toast.Id)">×</button>
            </article>
        }
    </div>
}

<style>
    .admin-toast-stack {
        position: fixed;
        right: 1.4rem;
        bottom: 1.2rem;
        width: min(360px, calc(100vw - 1.8rem));
        display: grid;
        gap: 0.65rem;
        z-index: 1000;
    }

    .admin-toast-card {
        background: #fff;
        border: 1px solid rgba(122, 184, 0, 0.3);
        border-radius: 14px;
        box-shadow: 0 14px 30px rgba(40, 66, 47, 0.16);
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        padding: 0.72rem 0.78rem;
        animation: admin-toast-slide-in 240ms ease;
    }

    .admin-toast-icon {
        width: 30px;
        height: 30px;
        border-radius: 9px;
        flex-shrink: 0;
        background: rgba(122, 184, 0, 0.14);
        color: #3f5b13;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
    }

    .admin-toast-body {
        min-width: 0;
        flex: 1;
    }

    .admin-toast-title {
        margin: 0;
        color: #1a1f0e;
        font-size: 0.8rem;
        font-weight: 700;
        line-height: 1.25;
    }

    .admin-toast-message {
        margin: 0.16rem 0 0;
        color: #576441;
        font-size: 0.75rem;
        line-height: 1.38;
    }

    .admin-toast-action {
        margin-top: 0.45rem;
        border: 0;
        border-radius: 999px;
        background: #2f5a28;
        color: #f4f9e9;
        font-size: 0.67rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        padding: 0.25rem 0.58rem;
        cursor: pointer;
    }

    .admin-toast-dismiss {
        border: 0;
        background: transparent;
        color: #8b9678;
        font-size: 1rem;
        line-height: 1;
        cursor: pointer;
        flex-shrink: 0;
    }

    @@media (max-width: 900px) {
        .admin-toast-stack {
            right: 0.8rem;
            left: 0.8rem;
            width: auto;
            bottom: 0.8rem;
        }
    }

    @@keyframes admin-toast-slide-in {
        from {
            transform: translateX(24px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

@code {
    [Parameter] public bool IsSystemAdmin { get; set; }
    [Parameter] public string? UserId { get; set; }

    private readonly List<NotificationDto> toasts = new();
    private HubConnection? _hub;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId) || _hub is not null) return;
        await StartHubAsync();
    }

    private async Task StartHubAsync()
    {
        var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
        var cookieStr = string.Join("; ", cookies?.Select(c => $"{c.Key}={c.Value}") ?? []);

        _hub = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chathub"), options =>
            {
                options.Headers.Add("Cookie", cookieStr);
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<NotificationDto>("ReceiveNotification", async (dto) =>
        {
            if (IsOnAdminNotificationPage()) return;

            await InvokeAsync(async () =>
            {
                toasts.Insert(0, dto);
                if (toasts.Count > 3)
                {
                    toasts.RemoveAt(toasts.Count - 1);
                }

                StateHasChanged();
                await Task.Delay(5000);
                Dismiss(dto.Id);
            });
        });

        await _hub.StartAsync();
    }

    private bool IsOnAdminNotificationPage()
    {
        var relative = "/" + Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
        var expected = IsSystemAdmin ? "/admin/system/notifications" : "/admin/business/notifications";
        return relative.StartsWith(expected, StringComparison.OrdinalIgnoreCase);
    }

    private void OpenAction(NotificationDto item)
    {
        Dismiss(item.Id);
        Navigation.NavigateTo(ResolveNotificationUrl(item));
    }

    private void Dismiss(Guid id)
    {
        var removed = toasts.RemoveAll(t => t.Id == id);
        if (removed > 0)
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private static string GetCategoryGlyph(NotificationType type)
    {
        return type switch
        {
            NotificationType.AdminWarning => "W",
            NotificationType.AdminReportAlert => "R",
            NotificationType.NewFollower => "F",
            NotificationType.StoryReaction => "S",
            _ => "N",
        };
    }

    private static string ResolveNotificationUrl(NotificationDto dto)
    {
        return dto.Type switch
        {
            NotificationType.AdminWarning => "/admin/system/security-alerts",
            NotificationType.AdminReportAlert => "/admin/business/reports",
            _ => "/admin/business/notifications",
        };
    }

    private static string GetToastTitle(NotificationType type)
    {
        return type switch
        {
            NotificationType.AdminWarning => "System warning",
            NotificationType.AdminReportAlert => "Report escalation",
            NotificationType.NewFollower => "New follower",
            NotificationType.StoryReaction => "Story reaction",
            _ => "Notification",
        };
    }

    private static string GetActionLabel(NotificationType type)
    {
        return type switch
        {
            NotificationType.AdminWarning => "Open security",
            NotificationType.AdminReportAlert => "Open reports",
            _ => "View",
        };
    }

    public void Dispose()
    {
        _ = DisposeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
        }
    }
}
