@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject INotificationService NotificationService
@inject IHttpContextAccessor HttpContextAccessor

<button type="button"
        class="admin-notification-bell"
        @onclick="GoToNotifications"
        aria-label="Open admin notifications"
        title="Admin notifications">
    <svg width="19" height="19" fill="none" viewBox="0 0 24 24"
         stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
    </svg>

    @if (UnreadCount > 0)
    {
        <span class="admin-notification-bell-count">@(UnreadCount > 99 ? "99+" : UnreadCount)</span>
    }
</button>

<style>
    .admin-notification-bell {
        position: relative;
        width: 42px;
        height: 42px;
        border: 1px solid rgba(122, 184, 0, 0.32);
        background: #ffffff;
        color: #2f5a28;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 22px rgba(40, 66, 47, 0.13);
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
    }

    .admin-notification-bell:hover {
        transform: translateY(-1px);
        border-color: rgba(122, 184, 0, 0.5);
        box-shadow: 0 14px 28px rgba(40, 66, 47, 0.17);
    }

    .admin-notification-bell-count {
        position: absolute;
        top: -6px;
        right: -7px;
        min-width: 18px;
        height: 18px;
        border-radius: 999px;
        background: #c63a1e;
        border: 2px solid #ffffff;
        color: #ffffff;
        font-size: 10px;
        font-weight: 700;
        line-height: 1;
        padding: 0 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
</style>

@code {
    [Parameter] public bool IsSystemAdmin { get; set; }
    [Parameter] public string? UserId { get; set; }

    private int UnreadCount;
    private HubConnection? _hub;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId)) return;

        await RefreshUnreadAsync();
        if (_hub is null)
        {
            Navigation.LocationChanged += OnLocationChanged;
            await StartHubAsync();
        }
    }

    private async Task StartHubAsync()
    {
        var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
        var cookieStr = string.Join("; ", cookies?.Select(c => $"{c.Key}={c.Value}") ?? []);

        _hub = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chathub"), options =>
            {
                options.Headers.Add("Cookie", cookieStr);
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<NotificationDto>("ReceiveNotification", async (_) =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshUnreadAsync();
                StateHasChanged();
            });
        });

        await _hub.StartAsync();
    }

    private async Task RefreshUnreadAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId))
        {
            UnreadCount = 0;
            return;
        }

        UnreadCount = await NotificationService.GetUnreadCountAsync(UserId);
    }

    private void GoToNotifications()
    {
        var target = IsSystemAdmin ? "/admin/system/notifications" : "/admin/business/notifications";
        Navigation.NavigateTo(target);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshUnreadAsync();
            StateHasChanged();
        });
    }

    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        if (_hub is not null)
        {
            await _hub.DisposeAsync();
        }
    }
}
