@page "/notifications"
@using Kotoba.Modules.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@inject INotificationService NotificationService
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@implements IAsyncDisposable
<style>
    .notif-page {
        min-height: 100vh;        
        background: var(--bg, #f4f7f0);
        padding: 0;
        font-family: 'DM Sans', sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .notif-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 24px 32px;        
        border: none !important;
        box-shadow: none !important;
        border-bottom: 1px solid rgba(0,0,0,0.06);
        background-color:#fff;
    }

    .notif-title {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 20px;
        color: var(--text, #1a1f0e);
        letter-spacing: -0.3px;
        line-height: 1;
    }

    .notif-subtitle {
        font-size: 12px;
        color: var(--muted, #888);
        margin-top: 3px;
    }

    .notif-container {        
        width: 100%;        
        display: flex;
        flex-direction: column;
        gap: 8px;
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
    }

    .notif-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 80px 0;
        gap: 12px;
        text-align: center;
    }

    .notif-empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 24px;
        background: rgba(122,184,0,0.1);
        border: 2px dashed rgba(122,184,0,0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--lime, #7ab800);
        margin-bottom: 4px;
    }

    .notif-empty-title {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 18px;
        color: var(--text, #1a1f0e);
    }

    .notif-empty-sub {
        font-size: 13px;
        color: var(--muted, #aaa);
        max-width: 240px;
        line-height: 1.5;
    }

    .notif-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 20px;
        padding: 24px 32px;
    }

    .notif-group-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--muted, #aaa);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        padding: 0 4px;
        margin-bottom: 4px;
    }

    .notif-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: 16px;
        cursor: pointer;
        transition: background .15s, transform .1s;
        background: #fff;
        border: 1px solid transparent;
    }

        .notif-item:hover {
            background: #f8fbf2;
            border-color: rgba(122,184,0,0.15);
            transform: translateX(2px);
        }

        .notif-item.unread {
            border-color: rgba(122,184,0,0.2);
            box-shadow: 0 2px 12px rgba(122,184,0,0.08);
        }

    .notif-icon-wrap {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

        .notif-icon-wrap.follow {
            background: rgba(52,152,219,0.12);
        }

        .notif-icon-wrap.story {
            background: rgba(231,76,60,0.10);
        }

        .notif-icon-wrap.warning {
            background: rgba(230,126,34,0.12);
        }

        .notif-icon-wrap.report {
            background: rgba(192,57,43,0.10);
        }

        .notif-icon-wrap.default {
            background: rgba(122,184,0,0.10);
        }

    .notif-content {
        flex: 1;
        min-width: 0;
    }

    .notif-msg {
        font-size: 13px;
        color: var(--text, #1a1f0e);
        line-height: 1.45;
        font-weight: 500;
    }

    .notif-time {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 11px;
        color: var(--muted, #aaa);
        margin-top: 4px;
    }

    .notif-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--lime, #7ab800);
        flex-shrink: 0;
        animation: pulse-dot 2s infinite;
    }

    @@keyframes pulse-dot {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: 0.6;
            transform: scale(0.85);
        }
    }
</style>

<div class="notif-page">
    <div class="notif-container">

        @* Header *@
        <div class="notif-header">
            <div style="display:flex;flex-direction:column;gap:6px;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:36px;height:36px;border-radius:12px;background:rgba(122,184,0,0.15);
                        display:flex;align-items:center;justify-content:center;">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24"
                             stroke="var(--lime,#7ab800)" stroke-width="2">
                            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 01-3.46 0" />
                        </svg>
                    </div>
                    <div class="notif-title">Notifications</div>
                </div>
                <div class="notif-subtitle">
                    @if (notifications.Any(n => !n.IsRead))
                    {
                        <span style="color:var(--lime,#7ab800);font-weight:600;">
                            @notifications.Count(n => !n.IsRead) unread
                        </span>
                        <span style="margin:0 6px;opacity:.3;">·</span>
                        <span>@notifications.Count total</span>
                    }                   
                </div>
            </div>
            @if (notifications.Any(n => !n.IsRead))
            {
                <button class="mark-all-btn" @onclick="MarkAll">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="2.5">
                        <path d="M20 6L9 17l-5-5" />
                    </svg>
                    Mark all read
                </button>
            }
        </div>

        @* Empty state *@
        @if (!notifications.Any())
        {
            <div class="notif-empty">
                <div class="notif-empty-icon">
                    <svg width="32" height="32" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="1.5">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 01-3.46 0" />
                    </svg>
                </div>
                <div class="notif-empty-title">Nothing here yet</div>
                <div class="notif-empty-sub">
                    We'll notify you when something happens
                </div>
            </div>
        }
        else
        {
            @* Group by date *@
            @foreach (var group in GroupedNotifications)
            {
                <div class="notif-group">
                    <div class="notif-group-label">@group.Key</div>
                    @foreach (var n in group.Value)
                    {
                        <div class="notif-item @(n.IsRead ? "" : "unread")"
                             @onclick="() => HandleClick(n)">

                            @* Icon badge *@
                            <div class="notif-icon-wrap @GetIconClass(n.Type)">
                                <span>@GetIcon(n.Type)</span>
                            </div>

                            @* Content *@
                            <div class="notif-content">
                                <div class="notif-msg">@n.Message</div>
                                <div class="notif-time">
                                    <svg width="10" height="10" fill="none" viewBox="0 0 24 24"
                                         stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <path d="M12 6v6l4 2" />
                                    </svg>
                                    @FormatTime(n.CreatedAt)
                                </div>
                            </div>

                            @* Unread dot *@
                            @if (!n.IsRead)
                            {
                                <div class="notif-dot"></div>
                            }
                            else
                            {
                                <div style="width:8px;flex-shrink:0;"></div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [CascadingParameter] public UserProfile? CurrentUserProfile { get; set; }
    private List<NotificationDto> notifications = new();
    private HubConnection? _hub;

    protected override async Task OnInitializedAsync()
    {
        if (CurrentUserProfile?.UserId == null) return;

        notifications = await NotificationService
            .GetNotificationsAsync(CurrentUserProfile.UserId);

        // Mark all read khi vào trang
        await NotificationService.MarkAllAsReadAsync(CurrentUserProfile.UserId);
        notifications.ForEach(n => n.IsRead = true);

        await StartHubAsync();
    }

    private async Task StartHubAsync()
    {
        var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
        var cookieStr = string.Join("; ", cookies?.Select(c => $"{c.Key}={c.Value}") ?? []);

        _hub = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/chathub"), options =>
            {
                options.Headers.Add("Cookie", cookieStr);
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<NotificationDto>("ReceiveNotification", async (dto) =>
        {
            await InvokeAsync(async () =>
            {
                // Thêm vào đầu danh sách
                notifications.Insert(0, dto);

                // Mark read ngay vì đang ở trang notifications
                await NotificationService.MarkAsReadAsync(dto.Id);
                dto.IsRead = true;

                StateHasChanged();
            });
        });

        await _hub.StartAsync();
    }

    private Dictionary<string, List<NotificationDto>> GroupedNotifications
    {
        get
        {
            var result = new Dictionary<string, List<NotificationDto>>();
            foreach (var n in notifications)
            {
                var label = GetDateLabel(n.CreatedAt);
                if (!result.ContainsKey(label))
                    result[label] = new();
                result[label].Add(n);
            }
            return result;
        }
    }

    private static string GetDateLabel(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var today = DateTime.Today;
        var diff = (today - local.Date).Days;
        return diff switch
        {
            0 => "Today",
            1 => "Yesterday",
            <= 7 => "This week",
            _ => local.ToString("MMMM yyyy")
        };
    }  

    private async Task MarkAll()
    {
        if (CurrentUserProfile?.UserId == null) return;
        await NotificationService.MarkAllAsReadAsync(CurrentUserProfile.UserId);
        notifications.ForEach(n => n.IsRead = true);
        StateHasChanged();
    }

    private async Task HandleClick(NotificationDto n)
    {
        await NotificationService.MarkAsReadAsync(n.Id);
        n.IsRead = true;
        StateHasChanged();
    }

    private static string GetIcon(NotificationType type) => type switch
    {
        NotificationType.NewFollower => "👤",
        NotificationType.StoryReaction => "❤️",
        NotificationType.AdminWarning => "⚠️",
        NotificationType.AdminReportAlert => "🚩",
        _ => "🔔"
    };

    private static string GetIconClass(NotificationType type) => type switch
    {
        NotificationType.NewFollower => "follow",
        NotificationType.StoryReaction => "story",
        NotificationType.AdminWarning => "warning",
        NotificationType.AdminReportAlert => "report",
        _ => "default"
    };

    private static string FormatTime(DateTime utc)
    {
        var delta = DateTime.UtcNow - utc;
        if (delta.TotalMinutes < 1) return "just now";
        if (delta.TotalHours < 1) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalDays < 1) return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays < 7) return $"{(int)delta.TotalDays}d ago";
        return utc.ToLocalTime().ToString("dd/MM/yyyy");
    }
    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
            await _hub.DisposeAsync();
    }
}
