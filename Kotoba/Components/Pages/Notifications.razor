@page "/notifications"
@using Kotoba.Modules.Domain.Enums
@inject INotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider

<div class="notif-page">
    <div class="notif-container">

        @* Header *@
        <div class="notif-header">
            <div style="display:flex;flex-direction:column;gap:6px;">
                <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:36px;height:36px;border-radius:12px;background:rgba(122,184,0,0.15);
                        display:flex;align-items:center;justify-content:center;">
                        <svg width="18" height="18" fill="none" viewBox="0 0 24 24"
                             stroke="var(--lime,#7ab800)" stroke-width="2">
                            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                            <path d="M13.73 21a2 2 0 01-3.46 0" />
                        </svg>
                    </div>
                    <div class="notif-title">Notifications</div>
                </div>
                <div class="notif-subtitle">
                    @if (notifications.Any(n => !n.IsRead))
                    {
                        <span style="color:var(--lime,#7ab800);font-weight:600;">
                            @notifications.Count(n => !n.IsRead) unread
                        </span>
                        <span style="margin:0 6px;opacity:.3;">·</span>
                        <span>@notifications.Count total</span>
                    }
                    else
                    {
                        <span>✓ All caught up</span>
                    }
                </div>
            </div>
            @if (notifications.Any(n => !n.IsRead))
            {
                <button class="mark-all-btn" @onclick="MarkAll">
                    <svg width="13" height="13" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="2.5">
                        <path d="M20 6L9 17l-5-5" />
                    </svg>
                    Mark all read
                </button>
            }
        </div>

        @* Empty state *@
        @if (!notifications.Any())
        {
            <div class="notif-empty">
                <div class="notif-empty-icon">
                    <svg width="32" height="32" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="1.5">
                        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 01-3.46 0" />
                    </svg>
                </div>
                <div class="notif-empty-title">Nothing here yet</div>
                <div class="notif-empty-sub">
                    We'll notify you when something happens
                </div>
            </div>
        }
        else
        {
            @* Group by date *@
            @foreach (var group in GroupedNotifications)
            {
                <div class="notif-group">
                    <div class="notif-group-label">@group.Key</div>
                    @foreach (var n in group.Value)
                    {
                        <div class="notif-item @(n.IsRead ? "" : "unread")"
                             @onclick="() => HandleClick(n)">

                            @* Icon badge *@
                            <div class="notif-icon-wrap @GetIconClass(n.Type)">
                                <span>@GetIcon(n.Type)</span>
                            </div>

                            @* Content *@
                            <div class="notif-content">
                                <div class="notif-msg">@FormatNotification(n)</div>
                                <div class="notif-time">
                                    <svg width="10" height="10" fill="none" viewBox="0 0 24 24"
                                         stroke="currentColor" stroke-width="2">
                                        <circle cx="12" cy="12" r="10" />
                                        <path d="M12 6v6l4 2" />
                                    </svg>
                                    @FormatTime(n.CreatedAt)
                                </div>
                            </div>

                            @* Unread dot *@
                            @if (!n.IsRead)
                            {
                                <div class="notif-dot"></div>
                            }
                            else
                            {
                                <div style="width:8px;flex-shrink:0;"></div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [CascadingParameter] public UserProfile? CurrentUserProfile { get; set; }
    private List<NotificationDto> notifications = new();

    private Dictionary<string, List<NotificationDto>> GroupedNotifications
    {
        get
        {
            var result = new Dictionary<string, List<NotificationDto>>();
            foreach (var n in notifications)
            {
                var label = GetDateLabel(n.CreatedAt);
                if (!result.ContainsKey(label))
                    result[label] = new();
                result[label].Add(n);
            }
            return result;
        }
    }

    private static string GetDateLabel(DateTime utc)
    {
        var local = utc.ToLocalTime();
        var today = DateTime.Today;
        var diff = (today - local.Date).Days;
        return diff switch
        {
            0 => "Today",
            1 => "Yesterday",
            <= 7 => "This week",
            _ => local.ToString("MMMM yyyy")
        };
    }

    protected override async Task OnInitializedAsync()
{
    var authState = await AuthStateProvider.GetAuthenticationStateAsync();
    var user = authState.User;

    var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    if (string.IsNullOrEmpty(userId)) return;

    notifications = await NotificationService.GetNotificationsAsync(userId);
    await NotificationService.MarkAllAsReadAsync(userId);

    notifications.ForEach(n => n.IsRead = true);
}

    private async Task MarkAll()
    {
        if (CurrentUserProfile?.UserId == null) return;
        await NotificationService.MarkAllAsReadAsync(CurrentUserProfile.UserId);
        notifications.ForEach(n => n.IsRead = true);
        StateHasChanged();
    }

    private async Task HandleClick(NotificationDto n)
    {
        await NotificationService.MarkAsReadAsync(n.Id);
        n.IsRead = true;
        StateHasChanged();
    }

    private static string GetIcon(NotificationType type) => type switch
    {
        NotificationType.NewFollower => "👤",
        NotificationType.StoryReaction => "👍",
        NotificationType.StorySeen => "💬",
        NotificationType.AdminWarning => "⚠️",
        NotificationType.AdminReportAlert => "🚩",
        _ => "🔔"
    };

    private static string GetIconClass(NotificationType type) => type switch
    {
        NotificationType.NewFollower => "follow",
        NotificationType.StoryReaction => "story",
        NotificationType.StorySeen => "story",
        NotificationType.AdminWarning => "warning",
        NotificationType.AdminReportAlert => "report",
        _ => "default"
    };

    private static string FormatTime(DateTime utc)
    {
        var delta = DateTime.UtcNow - utc;
        if (delta.TotalMinutes < 1) return "just now";
        if (delta.TotalHours < 1) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalDays < 1) return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays < 7) return $"{(int)delta.TotalDays}d ago";
        return utc.ToLocalTime().ToString("dd/MM/yyyy");
    }

    private string FormatNotification(NotificationDto n)
    {
        return n.Type switch
        {
            NotificationType.NewMessage
                => $"{n.ActorName}: {TrimMessage(n.Message)}",

            NotificationType.NewFollower
                => $"{n.ActorName} started following you",

            NotificationType.StoryReaction
                => $"{n.ActorName} reacted to your story",

            NotificationType.AdminWarning
                => $"Admin warning: {n.Message}",

            NotificationType.AdminReportAlert
                => $"Report alert: {n.Message}",

            _ => n.Message
        };
    }

    private static string TrimMessage(string msg)
    {
        if (string.IsNullOrEmpty(msg)) return "";
        return msg.Length > 40 ? msg.Substring(0, 40) + "..." : msg;
    }
}
