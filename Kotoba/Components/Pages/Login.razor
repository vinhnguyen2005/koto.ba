@page "/login"

<PageTitle>Login</PageTitle>

<div class="auth-page auth-page-login">
    <section class="auth-shell" aria-labelledby="login-title">
        <div class="auth-hero">
            <div class="auth-brand">
                <div class="auth-brand-mark">🍋</div>
                <div>
                    <div class="auth-brand-name">koto.ba</div>
                    <p class="auth-brand-copy">Secure messaging for your daily conversations.</p>
                </div>
            </div>

            <div class="auth-hero-copy">
                <p class="auth-eyebrow">Welcome back</p>
                <h1 id="login-title" class="auth-title">Sign in to your account</h1>
                <p class="auth-subtitle">Use your email and password to continue to chats, stories, and profile.</p>
            </div>

            <div class="auth-feature-list" aria-label="Highlights">
                <div class="auth-feature-item">Continue your conversations where you left off.</div>
                <div class="auth-feature-item">Manage account settings and profile in one place.</div>
                <div class="auth-feature-item">Stay signed in securely with your existing session.</div>
            </div>
        </div>

        <div class="auth-panel">
            <div class="auth-panel-header">
                <p class="auth-panel-kicker">Account access</p>
                <h2 class="auth-panel-title">Login</h2>
                <p class="auth-panel-copy">Enter your email and password to continue.</p>
            </div>

            @if (ShowError)
            {
                <div class="auth-alert" role="alert">
                    Invalid email or password.
                </div>
            }

            @if (ShowBanned)
            {
                <div class="auth-alert" role="alert">
                    Your account has been banned.
                    @if (!string.IsNullOrWhiteSpace(BanReason))
                    {
                        <div><strong>Reason:</strong> @BanReason</div>
                    }
                    else
                    {
                        <div>Please contact support.</div>
                    }
                </div>
            }

            <form method="post" action="/auth/login" class="auth-form">
                <AntiforgeryToken />

                <div class="auth-field">
                    <label class="auth-label" for="email">Email</label>
                    <input class="auth-input" id="email" name="Email" type="email" placeholder="you@koto.ba" autocomplete="email" required />
                </div>

                <div class="auth-field">
                    <label class="auth-label" for="password">Password</label>
                    <input class="auth-input" id="password" name="Password" type="password" placeholder="Enter your password" autocomplete="current-password" required />
                </div>

                <button type="submit" class="auth-submit">Sign in</button>
            </form>

            <p class="auth-footer">
                Don't have an account? <a href="/register">Create one</a>
            </p>
        </div>
    </section>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    [SupplyParameterFromQuery(Name = "banned")]
    public string? BannedCode { get; set; }

    [SupplyParameterFromQuery(Name = "reason")]
    public string? BanReason { get; set; }

    private bool ShowError => string.Equals(ErrorCode, "1", StringComparison.Ordinal);
    private bool ShowBanned => string.Equals(BannedCode, "1", StringComparison.Ordinal);
}
