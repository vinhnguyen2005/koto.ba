@using Kotoba.Modules.Domain.DTOs
@using Kotoba.Modules.Domain.Enums
@using Kotoba.Modules.Infrastructure.Services.Notifications
@using Microsoft.AspNetCore.SignalR.Client
@inject IConversationService conversationService
@inject IJSRuntime JS
@inject IUserService userService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject GlobalNotificationService GlobalNotificationService
@implements IAsyncDisposable
@inject IFollowService FollowService
<style>
	.profile-panel {
		width: 272px;
		background: var(--surface);
		border-left: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		overflow-y: auto;
		padding: 20px;
	}

	.profile-top {
		text-align: center;
		padding-bottom: 18px;
		border-bottom: 1px solid var(--border);
		margin-bottom: 18px;
	}

	.profile-avatar-lg {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--lime-light) 0%, var(--lime) 60%, #4A7C1F 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 32px;
		margin: 0 auto 10px;
		border: 3px solid rgba(122,184,0,0.25);
		box-shadow: 0 4px 16px rgba(122,184,0,0.2);
	}

	.profile-name {
		font-family: 'Syne', sans-serif;
		font-weight: 700;
		font-size: 15px;
		color: var(--text);
		margin-bottom: 3px;
	}

	.profile-username {
		font-size: 12px;
		color: var(--muted);
		margin-bottom: 10px;
	}

	.profile-status-badge {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 12px;
		background: rgba(34,197,94,0.1);
		border: 1px solid rgba(34,197,94,0.2);
		border-radius: 20px;
		font-size: 11px;
		color: #16A34A;
	}

	.status-dot-sm {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #22C55E;
	}

	.profile-section {
		margin-bottom: 18px;
	}

	.profile-section-title {
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		color: var(--muted);
		margin-bottom: 8px;
	}

	.member-card {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 10px;
		background: var(--surface2);
		border-radius: 10px;
		margin-bottom: 6px;
		border-left: 3px solid transparent;
		transition: all 0.2s;
		flex-wrap: wrap; /* ✅ Cho phép wrap */
	}

		.member-card.owner-card {
			background: rgba(192,57,43,0.08);
			border-left-color: #c0392b;
		}

		.member-card.admin-card {
			background: rgba(122,184,0,0.08);
			border-left-color: var(--lime);
		}

		.member-card.member-card-item {
			background: var(--surface3);
			border-left-color: #8A9468;
		}

	.member-avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--lime), #4A7C1F);
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 13px;
		font-weight: 700;
		flex-shrink: 0; /* ✅ Avatar không shrink */
	}

	.member-card.owner-card .member-avatar {
		background: linear-gradient(135deg, #c0392b, #a93226);
	}

	.member-card.admin-card .member-avatar {
		background: linear-gradient(135deg, var(--lime), #7AB800);
	}

	.member-info {
		flex: 1;
		min-width: 0; /* ✅ Important for ellipsis */
	}

	.member-name {
		font-size: 12px;
		font-weight: 600;
		color: var(--text);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.member-role {
		font-size: 11px;
		color: var(--muted);
		margin-top: 2px;
	}

	.member-actions {
		display: flex;
		gap: 6px; /* ✅ Space between buttons */
		flex-shrink: 0;
		flex-wrap: wrap; /* ✅ Allow wrap on small screens */
		align-items: center;
		margin-left: auto; /* ✅ Push buttons to right */
	}

	/* BUTTONS */
	.btn-sm {
		padding: 5px 10px;
		border: 1px solid var(--border);
		background: var(--surface3);
		border-radius: 6px;
		color: var(--text2);
		font-size: 11px;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s;
		font-family: 'DM Sans', sans-serif;
		white-space: nowrap; /* ✅ Text don't wrap */
		min-width: fit-content; /* ✅ Buttons have min width */
	}

		.btn-sm:hover {
			background: var(--lime-pale);
			border-color: var(--lime);
			color: var(--lime);
		}

		.btn-sm.btn-promote {
			background: rgba(122,184,0,0.1);
			color: var(--lime);
			border-color: rgba(122,184,0,0.2);
		}

			.btn-sm.btn-promote:hover {
				background: rgba(122,184,0,0.2);
			}

		.btn-sm.btn-demote,
		.btn-sm.btn-remove,
		.btn-sm.btn-transfer {
			background: rgba(192,57,43,0.1);
			color: #c0392b;
			border-color: rgba(192,57,43,0.2);
		}

			.btn-sm.btn-demote:hover,
			.btn-sm.btn-remove:hover,
			.btn-sm.btn-transfer:hover {
				background: rgba(192,57,43,0.2);
			}


	.profile-action-btn {
		width: 100%;
		padding: 9px 12px;
		background: var(--surface2);
		border: 1px solid var(--border);
		border-radius: 10px;
		color: var(--text2);
		font-size: 13px;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 6px;
		transition: all 0.2s;
		font-family: 'DM Sans', sans-serif;
	}

		.profile-action-btn:hover {
			background: var(--lime-pale);
			color: var(--lime);
			border-color: rgba(122,184,0,0.25);
		}

	.shared-media {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 4px;
	}

	.media-thumb {
		aspect-ratio: 1;
		background: var(--surface2);
		border-radius: 8px;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 18px;
		cursor: pointer;
		transition: opacity 0.2s;
		border: 1px solid var(--border);
		color: var(--text2);
	}

		.media-thumb:hover {
			opacity: 0.75;
		}

		.media-thumb.more {
			font-size: 12px;
			font-weight: 700;
			color: var(--lime);
			background: var(--lime-pale);
		}
</style>
@if (showConfirmRemoveModal)
{
	<div style="position:fixed;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:999;">
		<div style="background:white;padding:24px;border-radius:12px;width:300px;box-shadow:0 10px 40px rgba(0,0,0,0.15);">
			<div style="font-weight:600;font-size:14px;margin-bottom:8px;">Remove member?</div>
			<div style="font-size:13px;color:#666;margin-bottom:20px;">
				Remove <strong>@memberToRemove?.DisplayName</strong> from the group?
			</div>
			<div style="display:flex;gap:10px;">
				<button style="flex:1;padding:10px;background:#f0f0f0;border:none;border-radius:8px;cursor:pointer;font-weight:500;"
						@onclick="() => showConfirmRemoveModal = false">
					Cancel
				</button>
				<button style="flex:1;padding:10px;background:#c0392b;color:white;border:none;border-radius:8px;cursor:pointer;font-weight:500;"
						@onclick="ConfirmRemoveMember">
					Remove
				</button>
			</div>
		</div>
	</div>
}

@if (showConfirmLeaveModal)
{
	<div style="position:fixed;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:999;">
		<div style="background:white;padding:24px;border-radius:12px;width:300px;box-shadow:0 10px 40px rgba(0,0,0,0.15);">
			<div style="font-weight:600;font-size:14px;margin-bottom:8px;">Leave group?</div>
			<div style="font-size:13px;color:#666;margin-bottom:20px;">
				@if (isGroupOwner)
				{
					<span>You are the owner. Ownership will transfer to the senior admin or oldest member.</span>
				}
				else
				{
					<span>You will leave <strong>@conversation?.GroupName</strong>.</span>
				}
			</div>
			<div style="display:flex;gap:10px;">
				<button style="flex:1;padding:10px;background:#f0f0f0;border:none;border-radius:8px;cursor:pointer;font-weight:500;"
						@onclick="() => showConfirmLeaveModal = false">
					Cancel
				</button>
				<button style="flex:1;padding:10px;background:#c0392b;color:white;border:none;border-radius:8px;cursor:pointer;font-weight:500;"
						@onclick="ConfirmLeaveGroup">
					Leave
				</button>
			</div>
		</div>
	</div>
}
@if (conversation != null)
{
	<div class="profile-panel">
		<div class="profile-top">
			<div class="profile-avatar-lg">
				@(conversation.Type == ConversationType.Group ? "👥" : "🌿")
			</div>
			<div class="profile-name">@conversationName</div>
			<div class="profile-username">
				@(conversation.Type == ConversationType.Group
								? $"{members?.Count ?? 0} members"
								: "Direct message")
			</div>
			<div class="profile-status-badge">
				@if (ShouldShowStatusDot)
				{
					<div class="status-dot-sm"></div>
				}
				@StatusBadgeText
			</div>
		</div>

		@* OWNER *@
		@if (conversation.Type == ConversationType.Group && members != null)
		{
			var owner = members.FirstOrDefault(m => m.Role == "Owner");
			@if (owner != null)
			{
				<div class="profile-section">
					<div class="profile-section-title">👑 Owner</div>
					<div class="member-card owner-card">
						<div class="member-avatar">@owner.DisplayName[0]</div>
						<div class="member-info">
							<div class="member-name">@owner.DisplayName</div>
							<div class="member-role">Owner @(owner.UserId == CurrentUserId ? "(You)" : "")</div>
						</div>
						@if (isGroupOwner && owner.UserId != CurrentUserId)
						{
							<button class="btn-sm btn-transfer" @onclick="() => TransferOwnership(owner.UserId!)">
								Transfer
							</button>
						}
					</div>
				</div>
			}
		}

		@* ADMINS *@
		@if (conversation.Type == ConversationType.Group && members != null)
		{
			var admins = members.Where(m => m.Role == "Admin").ToList();
			@if (admins.Any())
			{
				<div class="profile-section">
					<div class="profile-section-title">⚙️ Admins (@admins.Count)</div>
					@foreach (var admin in admins)
					{
						var isMe = admin.UserId == CurrentUserId;
						<div class="member-card admin-card">
							<div class="member-avatar">@admin.DisplayName[0]</div>
							<div class="member-info">
								<div class="member-name">@admin.DisplayName</div>
								<div class="member-role">Admin @(isMe ? "(You)" : "")</div>
							</div>
							@if (isGroupOwner && !isMe)
							{
								<button class="btn-sm btn-demote" @onclick="() => DemoteFromAdmin(admin.UserId!)">
									Demote
								</button>
							}
						</div>
					}
				</div>
			}
		}

		@* MEMBERS *@
		@if (conversation.Type == ConversationType.Group && members != null)
		{
			var regularMembers = members.Where(m => m.Role == "Member").ToList();
			@if (regularMembers.Any())
			{
				<div class="profile-section">
					<div class="profile-section-title">👤 Members (@regularMembers.Count)</div>
					@foreach (var member in regularMembers)
					{
						var isMe = member.UserId == CurrentUserId;
						<div class="member-card member-card-item">
							<div class="member-avatar">@member.DisplayName[0]</div>
							<div class="member-info">
								<div class="member-name">@member.DisplayName</div>
								<div class="member-role">@(isMe ? "You" : "Member")</div>
							</div>
							@if ((isGroupOwner || isGroupAdmin) && !isMe)
							{
								<div class="member-actions">
									<button class="btn-sm btn-promote" @onclick="() => PromoteToAdmin(member.UserId!)">
										Make Admin
									</button>
									<button class="btn-sm btn-remove" @onclick="() => ConfirmRemove(member)">
										Remove
									</button>
								</div>
							}
						</div>
					}
				</div>
			}
		}

		@* ADD MEMBER (Owner + Admin only) *@
		@if (conversation.Type == ConversationType.Group && (isGroupOwner || isGroupAdmin))
		{
			<div class="profile-section">
				<div class="profile-section-title">Add Members</div>
				@if (!isAddingMember)
				{
					<button class="profile-action-btn" @onclick="() => isAddingMember = true">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" /></svg>
						Add Member
					</button>
				}
				else
				{
					<input style="width:100%;padding:10px;border:1.5px solid var(--lime);border-radius:10px;font-size:12px;outline:none;margin-bottom:8px;"
						   placeholder="Search users…"
						   @oninput="SearchUsersToAdd" />

					@if (addMemberResults.Any())
					{
						<div style="max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:4px;border:1px solid var(--border);border-radius:8px;padding:4px;margin-bottom:8px;">
							@foreach (var u in addMemberResults)
							{
								<div style="padding:8px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;font-size:12px;background:var(--surface3);"
									 @onclick="() => AddMemberAction(u.UserId!)">
									<span>@u.DisplayName</span>
									<span style="color:var(--lime);font-size:11px;">➕ Add</span>
								</div>
							}
						</div>
					}

					<button class="profile-action-btn" @onclick="() => isAddingMember = false">
						Cancel
					</button>
				}
			</div>
		}

		@* EDIT GROUP NAME (Owner + Admin only) *@
		@if (conversation.Type == ConversationType.Group && (isGroupOwner || isGroupAdmin))
		{
			<div class="profile-section">
				<div class="profile-section-title">📝 Group Name</div>
				@if (!isEditingName)
				{
					<div style="display:flex;justify-content:space-between;align-items:center;gap:10px;padding:10px;background:var(--surface2);border-radius:8px;">
						<span style="font-size:13px;font-weight:500;">@conversation.GroupName</span>
						<button class="btn-sm" style="padding:4px 8px;background:var(--surface3);border:1px solid var(--border);border-radius:6px;cursor:pointer;font-size:11px;" @onclick="() => { isEditingName = true; editNameValue = conversation.GroupName; }">
							✏️ Edit
						</button>
					</div>
				}
				else
				{
					<div style="display:flex;flex-direction:column;gap:8px;">
						<input style="width:100%;padding:10px;border:1.5px solid var(--lime);border-radius:8px;font-size:12px;outline:none;"
							   @bind="editNameValue"
							   maxlength="200"
							   placeholder="New group name…" />
						<div style="display:flex;gap:6px;">
							<button class="profile-action-btn" style="flex:1;background:var(--lime);color:#1A1F0E;font-weight:600;" @onclick="SaveGroupName">
								✓ Save
							</button>
							<button class="profile-action-btn" style="flex:1;" @onclick="() => isEditingName = false">
								Cancel
							</button>
						</div>
					</div>
				}
			</div>
		}

		@* Images *@
		@if (images.Any())
		{
			<div class="profile-section">
				<div class="profile-section-title">Shared images</div>
				<div class="shared-media">
					@foreach (var img in images.Take(9))
					{
						<div class="media-thumb" @onclick="() => OpenImage(img.Url)">
							<img src="@img.Url" alt="@img.FileName"
							style="width:100%;height:100%;object-fit:cover;display:block;" />
						</div>
					}
					@if (images.Count > 9)
					{
						<div class="media-thumb more">+@(images.Count - 9)</div>
					}
				</div>
			</div>
		}

		@* Files *@
		@if (files.Any())
		{
			<div class="profile-section">
				<div class="profile-section-title">Shared files</div>
				<div class="setting-files">
					@foreach (var f in files)
					{
						<a href="@f.Url" target="_blank" class="setting-file-row">
							<div class="setting-file-icon">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none"
								stroke="#378ADD" stroke-width="1.5" stroke-linecap="round">
									<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
									<polyline points="14 2 14 8 20 8" />
								</svg>
							</div>
							<div class="setting-file-info">
								<div class="setting-file-name">@f.FileName</div>
								<div class="setting-file-size">@FormatSize(f.Size)</div>
							</div>
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none"
							stroke="currentColor" stroke-width="2" stroke-linecap="round"
							style="color:var(--muted);flex-shrink:0">
								<path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6" />
								<polyline points="15 3 21 3 21 9" />
								<line x1="10" y1="14" x2="21" y2="3" />
							</svg>
						</a>
					}
				</div>
			</div>
		}

		@* Actions — UI only *@
		<div class="profile-section">
			<div class="profile-section-title">Actions</div>
			@if (conversation!.Type == ConversationType.Direct)
			{
				var otherUser = members?.FirstOrDefault(m => m.UserId != CurrentUserId);

				@if (otherUser != null && otherUser.UserId != CurrentUserId)
				{
					<button class="profile-action-btn" @onclick="ToggleFollowInConversation">
						<svg width="15" height="15" viewBox="0 0 24 24"
							 fill="@(isFollowing ? "currentColor" : "none")"
							 stroke="currentColor" stroke-width="2" stroke-linecap="round">
							<path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
						</svg>
						@(isFollowing ? "Following" : "Follow")
					</button>
				}
			}
			<button class="profile-action-btn">
				<svg width="15" height="15" viewBox="0 0 24 24" fill="none"
				stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" />
					<path d="M13.73 21a2 2 0 01-3.46 0" />
				</svg>
				Mute notifications
			</button>
			@if (conversation!.Type == ConversationType.Group)
			{
				<button class="profile-action-btn" style="color:#c0392b;" @onclick="HandleLeave">
					<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
						<path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
						<polyline points="16 17 21 12 16 7" />
						<line x1="21" y1="12" x2="9" y2="12" />
					</svg>
					Leave group
				</button>
			}
			@if (conversation!.Type == ConversationType.Direct){

				<button class="profile-action-btn" style="color:#c0392b;">
					<svg width="15" height="15" viewBox="0 0 24 24" fill="none"
					stroke="currentColor" stroke-width="2" stroke-linecap="round">
						<polyline points="3 6 5 6 21 6" />
						<path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
						<path d="M10 11v6M14 11v6" />
						<path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
					</svg>
					Delete conversation
				</button>
			}
		</div>
	</div>
}
@code {
	[Parameter] public string? ConversationId { get; set; }
	[Parameter] public string? CurrentUserId { get; set; }
	[Parameter] public EventCallback OnLeft { get; set; }
	private ConversationDto? conversation;
	private List<UserProfile>? members;
	private string? conversationName;
	private List<AttachmentDto> images = new();
	private List<AttachmentDto> files = new();
	private string _loadedId = string.Empty;
	private bool isFollowing;
	private bool isAddingMember = false;
	private string searchQuery = "";
	private List<UserProfile> addMemberResults = new();
	private bool isEditingName = false;
	private string editNameValue = "";
	private bool showConfirmRemoveModal = false;
	private UserProfile? memberToRemove;
	private bool showConfirmLeaveModal = false;
	private HubConnection? _settingHub;
	private string? _joinedConversationId;
	private bool isGroupOwner => members?.FirstOrDefault(m => m.UserId == CurrentUserId)?.Role == "Owner";
	private bool isGroupAdmin => members?.FirstOrDefault(m => m.UserId == CurrentUserId)?.Role == "Admin";
	private bool isGroupOwnerOrAdmin => isGroupOwner || isGroupAdmin;

	protected override void OnInitialized()
	{
		GlobalNotificationService.PresenceChanged += HandlePresenceChanged;
	}

	private string StatusBadgeText
	{
		get
		{
			if (conversation?.Type == ConversationType.Direct)
			{
				var other = members?.FirstOrDefault(m => m.UserId != CurrentUserId);
				if (other == null)
				{
					return "Unknown";
				}

				if (other.AccountStatus == AccountStatus.Deleted)
				{
					return "Deleted account";
				}

				if (other.AccountStatus == AccountStatus.Deactivated)
				{
					return "Deactivated";
				}

				if (other.IsOnline)
				{
					return "Online";
				}

				return $"Last seen {FormatRelativeLastSeen(other.LastSeenAt)}";
			}

			if (members == null || members.Count == 0)
			{
				return "No members";
			}

			var onlineCount = members.Count(m => m.IsOnline);
			return onlineCount == 1 ? "1 member online" : $"{onlineCount} members online";
		}
	}

	private bool ShouldShowStatusDot
	{
		get
		{
			if (conversation?.Type == ConversationType.Direct)
			{
				var other = members?.FirstOrDefault(m => m.UserId != CurrentUserId);
				return other?.IsOnline == true;
			}

			return members?.Any(m => m.IsOnline) == true;
		}
	}

	private static string FormatRelativeLastSeen(DateTime? lastSeenAt)
	{
		if (!lastSeenAt.HasValue)
		{
			return "a while ago";
		}

		var delta = DateTime.UtcNow - lastSeenAt.Value;
		if (delta < TimeSpan.Zero)
		{
			delta = TimeSpan.Zero;
		}

		if (delta < TimeSpan.FromMinutes(1))
		{
			return "just now";
		}

		if (delta < TimeSpan.FromHours(1))
		{
			var minutes = (int)Math.Floor(delta.TotalMinutes);
			return minutes == 1 ? "1 minute ago" : $"{minutes} minutes ago";
		}

		if (delta < TimeSpan.FromDays(1))
		{
			var hours = (int)Math.Floor(delta.TotalHours);
			return hours == 1 ? "1 hour ago" : $"{hours} hours ago";
		}

		var days = (int)Math.Floor(delta.TotalDays);
		return days == 1 ? "1 day ago" : $"{days} days ago";
	}

	protected override async Task OnParametersSetAsync()
	{
		if (string.IsNullOrEmpty(ConversationId) || _loadedId == ConversationId) return;
		await LoadAsync();
	}

	private void HandleLeave()
	{
		showConfirmLeaveModal = true;
	}

	private async Task LoadAsync()
	{
		_loadedId = ConversationId!;

		conversation = await conversationService.GetConversationDetailAsync(ConversationId!);
		if (conversation == null)
		{
			Console.WriteLine("Conversation is NULL!");
			return;
		}
		members = await conversationService.GetAllUsersInConversationAsync(ConversationId!);
		conversationName = conversation.Type == ConversationType.Group
			? conversation.GroupName
			: (members?.FirstOrDefault(m => m.UserId != CurrentUserId)?.DisplayName ?? "You");
		var messages = await conversationService.GetMessagesAsync(ConversationId!);

		var allAttachments = messages
			.SelectMany(m => m.Attachments ?? new())
			.ToList();

		images = allAttachments.Where(a => a.ContentType.StartsWith("image/")).ToList();
		files = allAttachments.Where(a => !a.ContentType.StartsWith("image/")).ToList();
		if (conversation.Type == ConversationType.Direct && members != null)
		{
			var otherUser = members.FirstOrDefault(m => m.UserId != CurrentUserId);
			if (otherUser != null && !string.IsNullOrEmpty(CurrentUserId))
			{
				isFollowing = await FollowService.IsFollowingAsync(CurrentUserId, otherUser.UserId);
			}
		}

		await EnsureHubAsync();
		StateHasChanged();
	}

	private async Task ToggleFollowInConversation()
	{
		if (string.IsNullOrEmpty(CurrentUserId) || conversation?.Type != ConversationType.Direct)
			return;

		var otherUser = members?.FirstOrDefault(m => m.UserId != CurrentUserId);
		if (otherUser == null)
			return;

		if (isFollowing)
		{
			await FollowService.UnfollowUserAsync(CurrentUserId, otherUser.UserId);
			isFollowing = false;
		}
		else
		{
			await FollowService.FollowUserAsync(CurrentUserId, otherUser.UserId);
			isFollowing = true;
		}

		StateHasChanged();
	}

