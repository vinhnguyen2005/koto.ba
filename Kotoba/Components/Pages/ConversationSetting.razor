	private async Task SearchUsersToAdd(ChangeEventArgs e)
	{
		var q = e.Value?.ToString() ?? "";
		searchQuery = q;

		if (string.IsNullOrEmpty(q))
		{
			addMemberResults.Clear();
			return;
		}

		var existing = members?.Select(m => m.UserId).ToHashSet() ?? new();
		addMemberResults = userService.GetUsersByDisplayNameAsync(q)
			.Where(u => !existing.Contains(u.UserId))
			.Take(5).ToList();
		StateHasChanged();
	}

	private async Task EnsureHubAsync()
	{

		if (_settingHub == null)
		{
			var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
			var cookieStr = string.Join("; ", cookies?.Select(c => $"{c.Key}={c.Value}") ?? []);

			_settingHub = new HubConnectionBuilder()
				.WithUrl(Navigation.ToAbsoluteUri("/chathub"), options =>
				{
					options.Headers.Add("Cookie", cookieStr);
				})
				.Build();

			_settingHub.On("MembersUpdated", async () =>
			{
				members = await conversationService.GetAllUsersInConversationAsync(ConversationId!);
				conversation = await conversationService.GetConversationDetailAsync(ConversationId!);
				await InvokeAsync(StateHasChanged);
			});

			await _settingHub.StartAsync();
		}

		if (_joinedConversationId != ConversationId)
		{
			if (!string.IsNullOrEmpty(_joinedConversationId))
				await _settingHub.InvokeAsync("LeaveConversation", _joinedConversationId);

			await _settingHub.InvokeAsync("JoinConversation", ConversationId);
			_joinedConversationId = ConversationId;
		}
	}

	public async ValueTask DisposeAsync()
	{
		GlobalNotificationService.PresenceChanged -= HandlePresenceChanged;
		if (_settingHub is not null)
			await _settingHub.DisposeAsync();
	}

	private void HandlePresenceChanged(PresenceUpdateDto update)
	{
		if (members == null || string.IsNullOrWhiteSpace(update.UserId))
		{
			return;
		}

		var changed = false;
		foreach (var member in members.Where(m => m.UserId == update.UserId))
		{
			member.IsOnline = update.IsOnline;
			if (!update.IsOnline)
			{
				member.LastSeenAt = update.LastSeenAt ?? DateTime.UtcNow;
			}
			changed = true;
		}

		if (changed)
		{
			_ = InvokeAsync(StateHasChanged);
		}
	}

