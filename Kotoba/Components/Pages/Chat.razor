@page "/chat"
@using Kotoba.Modules.Domain.Entities
@using Kotoba.Modules.Domain.Enums
@using Kotoba.Modules.Infrastructure.Data
@using Kotoba.Modules.Infrastructure.Services.Conversations
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthStateProvider
@inject IConversationService conversationService
@rendermode InteractiveServer
@inject IDbContextFactory<KotobaDbContext> DbFactory
@inject NavigationManager NavigationManager
<style>
    :root{
      --lime:#7AB800;--lime-bright:#8FD400;--lime-light:#C8E63A;
      --lime-pale:#EEF7C2;--lime-dim:rgba(122,184,0,0.10);--lime-dim2:rgba(122,184,0,0.16);
      --green-dark:#2D5016;--charcoal:#1A1F0E;
      --bg:#F0F4E4;--surface:#FFFFFF;--surface2:#F7FAF0;--surface3:#EDF2E0;
      --text:#1A1F0E;--text2:#4A5428;--muted:#8A9468;
      --border:rgba(122,184,0,0.18);--border2:rgba(122,184,0,0.10);
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);height:100vh;display:flex;overflow:hidden;color:var(--text);}

    /* ===== SIDEBAR NAV ===== */
    .sidebar-nav{width:64px;background:var(--green-dark);display:flex;flex-direction:column;align-items:center;padding:18px 0;gap:6px;z-index:10;}
    .nav-logo{width:40px;height:40px;background:var(--lime-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:#1A1F0E;margin-bottom:14px;cursor:pointer;box-shadow:0 4px 12px rgba(200,230,58,0.4);}
    .nav-divider{width:28px;height:1px;background:rgba(255,255,255,0.12);margin:6px 0;}
    .nav-btn{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all 0.2s;position:relative;color:rgba(255,255,255,0.45);text-decoration:none;}
    .nav-btn:hover{background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.9);}
    .nav-btn.active{background:rgba(200,230,58,0.2);color:var(--lime-light);}
    .nav-btn.active::before{content:'';position:absolute;left:-1px;width:3px;height:24px;background:var(--lime-light);border-radius:0 3px 3px 0;}
    .nav-badge{position:absolute;top:6px;right:6px;min-width:16px;height:16px;background:var(--lime-light);border-radius:8px;font-size:9px;font-weight:700;color:#1A1F0E;display:flex;align-items:center;justify-content:center;padding:0 3px;}
    .nav-bottom{margin-top:auto;}
    .avatar-nav{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--lime-light) 0%,var(--lime) 100%);display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;border:2px solid transparent;transition:border-color 0.2s;}
    .avatar-nav:hover{border-color:var(--lime-light);}

    /* ===== CHAT LIST ===== */
    .chat-list-panel{width:300px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;box-shadow:2px 0 8px rgba(45,80,22,0.04);}
    .panel-header{padding:18px 16px 14px;border-bottom:1px solid var(--border);}
    .panel-title{font-family:'Syne',sans-serif;font-weight:700;font-size:20px;color:var(--text);margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;}
    .header-actions{display:flex;gap:6px;}
    .icon-btn{width:32px;height:32px;border-radius:8px;background:var(--surface2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all 0.2s;}
    .icon-btn:hover{background:var(--lime-pale);color:var(--lime);border-color:var(--lime);}
    .search-box{position:relative;}
    .search-input{width:100%;padding:9px 12px 9px 34px;background:var(--surface2);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;outline:none;transition:all 0.25s;}
    .search-input::placeholder{color:#BCC4A0;}
    .search-input:focus{border-color:var(--lime);background:#fff;}
    .search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#BCC4A0;pointer-events:none;}

    .filter-tabs{display:flex;padding:10px 12px 0;gap:4px;}
    .filter-tab{padding:6px 14px;border-radius:20px;font-size:12px;font-weight:500;cursor:pointer;transition:all 0.2s;color:var(--muted);border:1px solid transparent;}
    .filter-tab.active{background:var(--lime-pale);color:var(--lime);border-color:rgba(122,184,0,0.25);font-weight:600;}
    .filter-tab:hover:not(.active){color:var(--text);background:var(--surface2);}

    .chat-list{overflow-y:auto;flex:1;padding:6px;}
    .chat-list::-webkit-scrollbar{width:3px;}
    .chat-list::-webkit-scrollbar-thumb{background:rgba(122,184,0,0.2);border-radius:2px;}

    .chat-item{display:flex;gap:10px;padding:10px 10px;border-radius:12px;cursor:pointer;transition:all 0.2s;position:relative;}
    .chat-item:hover{background:var(--surface2);}
    .chat-item.active{background:var(--lime-pale);}

    .chat-avatar{position:relative;flex-shrink:0;}
    .avatar-img{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#4A7C1F,#2D5016);display:flex;align-items:center;justify-content:center;font-size:20px;border:2px solid transparent;}
    .chat-item.active .avatar-img{border-color:rgba(122,184,0,0.35);}
    .online-dot{position:absolute;bottom:1px;right:1px;width:11px;height:11px;background:#22C55E;border-radius:50%;border:2px solid var(--surface);}
    .chat-item.active .online-dot{border-color:var(--lime-pale);}

    .chat-info{flex:1;min-width:0;}
    .chat-name-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;}
    .chat-name{font-weight:500;font-size:14px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    /* Unread: bold name + darker time */
    .chat-item.has-unread .chat-name{font-weight:700;color:var(--text);}
    .chat-item.has-unread .chat-time{color:var(--lime);font-weight:600;}
    .chat-time{font-size:11px;color:var(--muted);flex-shrink:0;margin-left:6px;}
    .chat-preview-row{display:flex;align-items:center;justify-content:space-between;gap:6px;}
    .chat-preview{font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
    .chat-preview.unread{color:var(--text);font-weight:600;}

    /* FIX: unread badge - small circle/pill, NOT full width bar */
    .unread-badge{flex-shrink:0;min-width:18px;height:18px;background:var(--lime);border-radius:9px;font-size:10px;font-weight:700;color:#1A1F0E;display:inline-flex;align-items:center;justify-content:center;padding:0 5px;}

    .section-label{padding:10px 10px 4px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);}

    /* ===== MAIN CHAT ===== */
    .chat-main{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--bg);}
    .chat-header{padding:0 20px;height:62px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;background:var(--surface);box-shadow:0 1px 4px rgba(45,80,22,0.05);}
    .chat-header-avatar{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#4A7C1F,#2D5016);display:flex;align-items:center;justify-content:center;font-size:17px;position:relative;}
    .header-online{position:absolute;bottom:0;right:0;width:10px;height:10px;background:#22C55E;border-radius:50%;border:2px solid var(--surface);}
    .chat-header-info{flex:1;}
    .chat-header-name{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--text);}
    .chat-header-status{font-size:11px;color:#22C55E;font-weight:500;}
    .chat-header-actions{display:flex;gap:4px;}

    /* Messages */
    .messages-area{flex:1;overflow-y:auto;padding:20px 24px;display:flex;flex-direction:column;gap:2px;}
    .messages-area::-webkit-scrollbar{width:4px;}
    .messages-area::-webkit-scrollbar-thumb{background:rgba(122,184,0,0.2);border-radius:2px;}
    .msg-date-divider{text-align:center;font-size:11px;color:var(--muted);padding:10px 0;display:flex;align-items:center;gap:12px;}
    .msg-date-divider::before,.msg-date-divider::after{content:'';flex:1;height:1px;background:var(--border);}

    .msg-group{margin-bottom:10px;display:flex;flex-direction:column;align-items:flex-start;}
    .msg-group.own{align-items:flex-end;}
    /* base row: received messages */
    .msg-row{display:flex;gap:8px;align-items:flex-end;margin-bottom:2px;}
    .msg-avatar-sm{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#4A7C1F,#2D5016);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}

    /* BUBBLES */
    .msg-bubble{
      padding:10px 14px;border-radius:18px;
      font-size:14px;line-height:1.55;word-break:break-word;
      max-width:360px;
    }
    /* received */
    .msg-row:not(.own) .msg-bubble{
      background:var(--surface);border:1px solid var(--border);
      border-bottom-left-radius:5px;color:var(--text);
      box-shadow:0 1px 4px rgba(45,80,22,0.06);
    }
    /* OWN messages */
    .msg-row.own{justify-content:flex-end;}
    .msg-row.own .msg-avatar-sm{display:none;}
    .msg-row.own .msg-bubble{
      background:var(--lime);color:#1A1F0E;
      border-bottom-right-radius:5px;font-weight:500;
      box-shadow:0 2px 8px rgba(122,184,0,0.25);
    }

    /* meta row — sits inside msg-group, inherits align-items:flex-end for own */
    .msg-meta{display:flex;align-items:center;gap:4px;padding:0 4px;margin-top:2px;}
    .msg-time{font-size:10px;color:var(--muted);}
    .msg-check{font-size:11px;color:var(--lime);}

    /* FIX: media image — fixed width, no overflow */
    .msg-image-wrap{
      display:inline-block;
      width:220px;          /* fixed width, never wider than bubble */
      border-radius:14px;overflow:hidden;
      margin-bottom:2px;border:1px solid var(--border);
      box-shadow:0 1px 4px rgba(45,80,22,0.06);
    }
    .msg-image{width:100%;height:150px;background:linear-gradient(135deg,var(--lime-pale),var(--surface3));display:flex;align-items:center;justify-content:center;font-size:36px;}
    .msg-image-caption{padding:8px 12px;background:var(--surface);font-size:13px;color:var(--text);}

    /* reactions sit flush below the bubble, offset by avatar width only */
    .msg-reactions{
      display:flex;gap:4px;
      margin-top:-6px;   /* overlap slightly under bubble */
      margin-left:36px;  /* align with bubble start (after avatar) */
      margin-bottom:2px;
    }
    .msg-group.own .msg-reactions{margin-left:0;}
    .reaction-chip{
      background:var(--surface);border:1px solid var(--border);
      border-radius:20px;padding:3px 9px;font-size:12px;
      cursor:pointer;transition:all 0.2s;
      box-shadow:0 1px 4px rgba(45,80,22,0.08);
    }
    .reaction-chip:hover{background:var(--lime-pale);border-color:var(--lime);transform:scale(1.08);}

    /* Typing */
    .typing-indicator{display:flex;gap:8px;align-items:center;padding:4px 0;}
    .typing-dots{background:var(--surface);border:1px solid var(--border);padding:10px 16px;border-radius:18px;border-bottom-left-radius:5px;display:flex;gap:4px;box-shadow:0 1px 4px rgba(45,80,22,0.06);}
    .dot{width:6px;height:6px;border-radius:50%;background:var(--lime);animation:bounce 1.4s infinite;opacity:0.7;}
    .dot:nth-child(2){animation-delay:.2s;}
    .dot:nth-child(3){animation-delay:.4s;}
    @@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-6px)}}

    /* Input area */
    .input-area{padding:12px 20px;border-top:1px solid var(--border);background:var(--surface);}
    .input-toolbar{display:flex;align-items:center;gap:6px;padding:10px 12px;background:var(--surface2);border:1.5px solid var(--border);border-radius:16px;transition:border-color 0.3s;}
    .input-toolbar:focus-within{border-color:var(--lime);box-shadow:0 0 0 3px rgba(122,184,0,0.08);}
    .input-tool-btn{width:32px;height:32px;border-radius:8px;border:none;background:transparent;color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0;}
    .input-tool-btn:hover{background:var(--lime-pale);color:var(--lime);}
    .msg-input{flex:1;border:none;background:transparent;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;outline:none;resize:none;max-height:120px;}
    .msg-input::placeholder{color:#BCC4A0;}
    .send-btn{width:36px;height:36px;background:var(--lime);border:none;border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all 0.2s;color:#1A1F0E;}
    .send-btn:hover{background:var(--lime-bright);transform:scale(1.05);}
    .send-btn:active{transform:scale(0.95);}

    /* ===== PROFILE PANEL ===== */
    .profile-panel{width:272px;background:var(--surface);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;padding:20px;}
    .profile-panel::-webkit-scrollbar{width:3px;}
    .profile-panel::-webkit-scrollbar-thumb{background:rgba(122,184,0,0.2);border-radius:2px;}
    .profile-top{text-align:center;padding-bottom:18px;border-bottom:1px solid var(--border);margin-bottom:18px;}
    .profile-avatar-lg{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--lime-light) 0%,var(--lime) 60%,#4A7C1F 100%);display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 10px;border:3px solid rgba(122,184,0,0.25);box-shadow:0 4px 16px rgba(122,184,0,0.2);}
    .profile-name{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--text);margin-bottom:3px;}
    .profile-username{font-size:12px;color:var(--muted);margin-bottom:10px;}
    .profile-status-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2);border-radius:20px;font-size:11px;color:#16A34A;}
    .status-dot-sm{width:6px;height:6px;border-radius:50%;background:#22C55E;}

    .profile-section{margin-bottom:18px;}
    .profile-section-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);margin-bottom:8px;}

    .copy-feature-card{background:linear-gradient(135deg,var(--lime-pale),rgba(122,184,0,0.06));border:1px solid rgba(122,184,0,0.25);border-radius:12px;padding:14px;margin-bottom:8px;}
    .copy-feature-title{font-size:12px;font-weight:700;color:var(--lime);margin-bottom:5px;display:flex;align-items:center;gap:6px;}
    .copy-feature-desc{font-size:11px;color:var(--text2);line-height:1.5;}

    .profile-action-btn{width:100%;padding:9px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:10px;color:var(--text2);font-size:13px;cursor:pointer;display:flex;align-items:center;gap:10px;margin-bottom:6px;transition:all 0.2s;font-family:'DM Sans',sans-serif;}
    .profile-action-btn:hover{background:var(--lime-pale);color:var(--lime);border-color:rgba(122,184,0,0.25);}

    /* FIX: shared media grid - proper thumbnails */
    .shared-media{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;}
    .media-thumb{aspect-ratio:1;background:var(--surface2);border-radius:8px;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;transition:opacity 0.2s;border:1px solid var(--border);color:var(--text2);}
    .media-thumb:hover{opacity:0.75;}
    .media-thumb.more{font-size:12px;font-weight:700;color:var(--lime);background:var(--lime-pale);}
</style>
<!-- CHAT LIST -->
<div class="chat-list-panel">
    <div class="panel-header">
        <div class="panel-title">
            Messages
            <div class="header-actions">
                <div class="icon-btn" title="New chat">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" /></svg>
                </div>
                <div class="icon-btn" title="Filter">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M3 4h18M7 8h10M11 12h2" /></svg>
                </div>
            </div>
        </div>
        <div class="search-box">
            <div class="search-icon"><svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg></div>
            <input class="search-input" name="searchConversation" placeholder="Search conversations…" @oninput="HandleSubmit">
        </div>
    </div>

    <div class="filter-tabs">
        <div class="filter-tab active">All</div>
        <div class="filter-tab">Unread</div>
        <div class="filter-tab">Groups</div>
    </div>

    <div class="chat-list">

        @* Search Users Result *@
        @if (users != null && users.Any())
        {
            <div class="section-label">Users</div>
            @foreach (var user in users)
            {
                <div class="chat-item" @onclick="() => SelectConversation(user)">
                    <div class="chat-avatar">
                        <div class="avatar-img">🥝</div>
                    </div>
                    <div class="chat-info">
                        <div class="chat-name-row">
                            <div class="chat-name">@user.DisplayName</div>
                        </div>
                    </div>
                </div>
            }
        }

        @* Search Groups Result *@
        @if(conversations != null && conversations.Any()){
            <div class="section-label">Groups</div>
            @foreach (var conv in conversations)
            {
                <div class="chat-item" @onclick="() => SelectConversation(conv)">
            <div class="chat-avatar">
                <div class="avatar-img">🥝</div>
            </div>
            <div class="chat-info">
                <div class="chat-name-row">
                    <div class="chat-name">@conv.GroupName</div>                    
                </div>                
            </div>
        </div>
            }
        }               
                
    </div>
</div>

@if (selectedConv != null)
{
    <!-- MAIN CHAT -->
    <div class="chat-main">
        <div class="chat-header">
            <div class="chat-header-avatar">
                🌿
                <div class="header-online"></div>
            </div>
            <div class="chat-header-info">
                <div class="chat-header-name">@selectedConv.GroupName</div>
                <div class="chat-header-status">● Online</div>
            </div>
            <div class="chat-header-actions">
                <div class="icon-btn" title="Voice call"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg></div>
                <div class="icon-btn" title="Video call"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 10l4.553-2.069A1 1 0 0121 8.82v6.36a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z" /></svg></div>
                <div class="icon-btn" title="Search"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg></div>
                <div class="icon-btn" title="More"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1" /><circle cx="19" cy="12" r="1" /><circle cx="5" cy="12" r="1" /></svg></div>
            </div>
        </div>

        <div class="messages-area" id="msgArea">
            <div class="msg-date-divider">Today, March 14</div>                        
        </div>

        <div class="input-area">
            <div class="input-toolbar">
                <button class="input-tool-btn" title="Emoji"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M8 13s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01" /></svg></button>
                <button class="input-tool-btn" title="Attach"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48" /></svg></button>
                <button class="input-tool-btn" title="Image"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><path d="M21 15l-5-5L5 21" /></svg></button>
                <textarea class="msg-input" placeholder="Type a message…" rows="1" id="msgInput" onkeydown="handleKey(event)"></textarea>
                <button class="input-tool-btn" title="Voice"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z" /><path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8" /></svg></button>
                <button class="send-btn" onclick="sendMessage()" title="Send"><svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" /></svg></button>
            </div>
        </div>
    </div>
}

<script>
function selectChat(item){
  document.querySelectorAll('.chat-item').forEach(i=>i.classList.remove('active'));
  item.classList.add('active');
}
function sendMessage(){
  const input=document.getElementById('msgInput');
  const text=input.value.trim();
  if(!text)return;
  const area=document.getElementById('msgArea');
  const typing=area.querySelector('.typing-indicator');
  const group=document.createElement('div');
  group.className='msg-group own';
  group.innerHTML=`
    <div class="msg-row own"><div class="msg-bubble">${esc(text)}</div></div>
    <div class="msg-meta"><span class="msg-time">Just now</span><span class="msg-check">✓</span></div>`;
  area.insertBefore(group,typing);
  input.value='';
  area.scrollTop=area.scrollHeight;
}
function handleKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}}
function esc(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
document.querySelectorAll('.filter-tab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    document.querySelectorAll('.filter-tab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
  });
});
</script>

@code {
    private KotobaDbContext? _context;
    private List<ConversationDto>? conversations;
    private List<UserProfile>? users;
    private ConversationDto? selectedConv;    
    private string? currentUserId;
    protected override void OnInitialized()
    {
        _context = DbFactory.CreateDbContext();                
    }
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        }
        if (string.IsNullOrEmpty(currentUserId))
        {
            NavigationManager.NavigateTo("/login", true);
            return;
        }
        //conversations = await conversationService.GetUserConversationsAsync(currentUserId);
    }

    private async Task HandleSubmit(ChangeEventArgs e)
    {        
        var searchValue = e?.Value?.ToString();
        if (_context != null && !string.IsNullOrEmpty(searchValue) && !string.IsNullOrEmpty(currentUserId))
        {
            conversations = await conversationService.FindGroupConversationsAsync(currentUserId, searchValue);
            users = await _context.Users
                .Where(u => u.DisplayName.Contains(searchValue))
                .Select(u => new UserProfile { UserId = u.Id, DisplayName = u.DisplayName })
                .ToListAsync();
            StateHasChanged();
        }
        else
        {
            conversations = new();
        }        
    }

    private Task SelectConversation(ConversationDto conv)
    {
        selectedConv = conv;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task SelectConversation(UserProfile user)
    {
        selectedConv = await conversationService.FindDirectConversationsAsync(currentUserId!, user.UserId);
        StateHasChanged();
    }
}
