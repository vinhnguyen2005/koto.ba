@page "/chat"
@page "/chat/{ConversationId}"
@inject AuthenticationStateProvider AuthStateProvider
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject NavigationManager Navigation

<style>
    /* Chat page: keep the outer page fixed; only inner panes scroll */
    .chat-shell {
        display: flex;
        flex: 1;
        min-height: 0;
        width: 100%;
        height: 100vh;
        overflow: hidden;
    }

    .chat-shell > .chat-list-panel {
        flex-shrink: 0;
        min-height: 0;
        height: 100%;
    }

    .chat-shell > .chat-main {
        min-height: 0;
        height: 100%;
    }

    @@media (max-width: 640.98px) {
        /* When layout switches to column, avoid hard clamping to 100vh. */
        .chat-shell {
            height: 100%;
        }
    }

    .setting-member {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        border-bottom: 0.5px solid var(--border);
    }

        .setting-member:last-child {
            border-bottom: none;
        }

    .setting-member-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--lime-pale);
        color: var(--lime);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        flex-shrink: 0;
        border: 1px solid rgba(122,184,0,0.25);
    }

    .setting-member-name {
        font-size: 13px;
        color: var(--text);
        font-weight: 500;
    }

    .setting-files {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .setting-file-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 10px;
        background: var(--surface2);
        border: 0.5px solid var(--border);
        border-radius: 10px;
        text-decoration: none;
        color: inherit; /* ✅ bỏ màu xanh link */
        transition: background 0.15s;
        overflow: hidden; /* ✅ chặn tràn */
    }

        .setting-file-row:hover {
            background: var(--lime-pale);
        }

    .setting-file-icon {
        width: 32px;
        height: 32px;
        background: #E6F1FB;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .setting-file-info {
        flex: 1;
        min-width: 0;
    }
    /* ✅ min-width:0 để ellipsis hoạt động */
    .setting-file-name {
        font-size: 12px;
        font-weight: 500;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis; /* ✅ cắt tên dài */
    }

    .setting-file-size {
        font-size: 11px;
        color: var(--muted);
        margin-top: 1px;
    }

    .setting-file-ext {
        flex-shrink: 0;
        color: var(--muted);
    }

    /* Actions danger */
    .profile-action-btn.danger {
        color: #c0392b;
    }

        .profile-action-btn.danger:hover {
            background: #fcebeb;
            border-color: #f09595;
            color: #c0392b;
        }
</style>

<div class="chat-shell">
    <ChatNav currentUserId="@currentUserId" />
    <ChatMain ConversationId="@ConversationId"
              currentUserId="@currentUserId"
              OnToggleSetting="ToggleSetting" />
    @if (showSetting && !string.IsNullOrEmpty(ConversationId))
    {
        <ConversationSetting ConversationId="@ConversationId"
                             CurrentUserId="@currentUserId" />
    }
</div>

@code {
	[Parameter] public string? ConversationId { get; set; }
	private string? currentUserId;
    private bool showSetting = false;

    private void ToggleSetting()
    {
        showSetting = !showSetting;
        StateHasChanged();
    }

	protected override async Task OnInitializedAsync()
	{
		var authState = await AuthStateProvider.GetAuthenticationStateAsync();
		var user = authState.User;
		if (user.Identity?.IsAuthenticated == true)
		{
			currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
		}
		if (string.IsNullOrEmpty(currentUserId))
		{
			Navigation.NavigateTo("/login", true);
			return;
		}
	}
}
