@inject IConversationService conversationService
@inject IUserService userService
@inject NavigationManager Navigation
@inject IConversationService conversationService
@using Kotoba.Modules.Infrastructure.Services.Conversations
@using Kotoba.Modules.Infrastructure.Services.Notifications
@using Kotoba.Modules.Domain.Entities
@using Kotoba.Modules.Domain.Enums
@using Kotoba.Modules.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<KotobaDbContext> DbFactory
@inject ICurrentThoughtService CurrentThoughtService
@using Kotoba.Modules.Domain.Interfaces
@implements IAsyncDisposable
@inject IHttpContextAccessor HttpContextAccessor
@inject ChatNotificationState NotifState
@using Microsoft.AspNetCore.SignalR.Client
<style>
	:root {
		--lime: #7AB800;
		--lime-bright: #8FD400;
		--lime-light: #C8E63A;
		--lime-pale: #EEF7C2;
		--lime-dim: rgba(122,184,0,0.10);
		--lime-dim2: rgba(122,184,0,0.16);
		--green-dark: #2D5016;
		--charcoal: #1A1F0E;
		--bg: #F0F4E4;
		--surface: #FFFFFF;
		--surface2: #F7FAF0;
		--surface3: #EDF2E0;
		--text: #1A1F0E;
		--text2: #4A5428;
		--muted: #8A9468;
		--border: rgba(122,184,0,0.18);
		--border2: rgba(122,184,0,0.10);
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

    body {
        font-family: 'DM Sans',sans-serif;
        background: var(--bg);
        min-height: 100vh;
        overflow-x: hidden;
        overflow-y: auto;
        color: var(--text);
    }


    /* ===== CHAT LIST ===== */
    .chat-list-panel {
        width: 300px;
        background: var(--surface);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        min-height: 0;
        height: 100%;
        overflow: hidden;
        flex-shrink: 0;
        box-shadow: 2px 0 8px rgba(45,80,22,0.04);
    }

	.panel-header {
		padding: 18px 16px 14px;
		border-bottom: 1px solid var(--border);
	}

	.panel-title {
		font-family: 'Syne',sans-serif;
		font-weight: 700;
		font-size: 20px;
		color: var(--text);
		margin-bottom: 12px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.header-actions {
		display: flex;
		gap: 6px;
	}

	.icon-btn {
		width: 32px;
		height: 32px;
		border-radius: 8px;
		background: var(--surface2);
		border: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		color: var(--muted);
		transition: all 0.2s;
	}

		.icon-btn:hover {
			background: var(--lime-pale);
			color: var(--lime);
			border-color: var(--lime);
		}

	.search-box {
		position: relative;
	}

	.search-input {
		width: 100%;
		padding: 9px 12px 9px 34px;
		background: var(--surface2);
		border: 1.5px solid var(--border);
		border-radius: 10px;
		color: var(--text);
		font-family: 'DM Sans',sans-serif;
		font-size: 13px;
		outline: none;
		transition: all 0.25s;
	}

		.search-input::placeholder {
			color: #BCC4A0;
		}

		.search-input:focus {
			border-color: var(--lime);
			background: #fff;
		}

	.search-icon {
		position: absolute;
		left: 10px;
		top: 50%;
		transform: translateY(-50%);
		color: #BCC4A0;
		pointer-events: none;
	}

	.filter-tabs {
		display: flex;
		padding: 10px 12px 0;
		gap: 4px;
	}

	.filter-tab {
		padding: 6px 14px;
		border-radius: 20px;
		font-size: 12px;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s;
		color: var(--muted);
		border: 1px solid transparent;
	}

		.filter-tab.active {
			background: var(--lime-pale);
			color: var(--lime);
			border-color: rgba(122,184,0,0.25);
			font-weight: 600;
		}

		.filter-tab:hover:not(.active) {
			color: var(--text);
			background: var(--surface2);
		}

	.chat-list {
		overflow-y: auto;
		flex: 1;
		padding: 6px;
	}

		.chat-list::-webkit-scrollbar {
			width: 3px;
		}

		.chat-list::-webkit-scrollbar-thumb {
			background: rgba(122,184,0,0.2);
			border-radius: 2px;
		}

	.chat-item {
		display: flex;
		gap: 10px;
		padding: 10px 10px;
		border-radius: 12px;
		cursor: pointer;
		transition: all 0.2s;
		position: relative;
	}

		.chat-item:hover {
			background: var(--surface2);
		}

		.chat-item.active {
			background: var(--lime-pale);
		}

	.chat-avatar {
		position: relative;
		flex-shrink: 0;
	}

	.avatar-img {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: linear-gradient(135deg,#4A7C1F,#2D5016);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 20px;
		border: 2px solid transparent;
	}

	.chat-item.active .avatar-img {
		border-color: rgba(122,184,0,0.35);
	}

	.online-dot {
		position: absolute;
		bottom: 1px;
		right: 1px;
		width: 11px;
		height: 11px;
		background: #22C55E;
		border-radius: 50%;
		border: 2px solid var(--surface);
	}

	.chat-item.active .online-dot {
		border-color: var(--lime-pale);
	}

	.chat-info {
		flex: 1;
		min-width: 0;
	}

	.chat-name-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 3px;
	}

	.chat-name {
		font-weight: 500;
		font-size: 14px;
		color: var(--text);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.chat-item.has-unread .chat-name {
		font-weight: 700;
		color: var(--text);
	}

	.chat-item.has-unread .chat-time {
		color: var(--lime);
		font-weight: 600;
	}

	.chat-time {
		font-size: 11px;
		color: var(--muted);
		flex-shrink: 0;
		margin-left: 6px;
	}

	.chat-preview-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 6px;
	}

	.chat-preview {
		font-size: 12px;
		color: var(--muted);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		flex: 1;
	}

		.chat-preview.unread {
			color: var(--text);
			font-weight: 600;
		}

	.unread-badge {
		flex-shrink: 0;
		min-width: 18px;
		height: 18px;
		background: var(--lime);
		border-radius: 9px;
		font-size: 10px;
		font-weight: 700;
		color: #1A1F0E;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0 5px;
	}

	.section-label {
		padding: 10px 10px 4px;
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		color: var(--muted);
	}

	/* ===== MAIN CHAT ===== */
	.chat-main {
		flex: 1;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		background: var(--bg);
	}

	.chat-header {
		padding: 0 20px;
		height: 62px;
		border-bottom: 1px solid var(--border);
		display: flex;
		align-items: center;
		gap: 12px;
		background: var(--surface);
		box-shadow: 0 1px 4px rgba(45,80,22,0.05);
	}

	.chat-header-avatar {
		width: 38px;
		height: 38px;
		border-radius: 50%;
		background: linear-gradient(135deg,#4A7C1F,#2D5016);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 17px;
		position: relative;
	}

	.header-online {
		position: absolute;
		bottom: 0;
		right: 0;
		width: 10px;
		height: 10px;
		background: #22C55E;
		border-radius: 50%;
		border: 2px solid var(--surface);
	}

	.chat-header-info {
		flex: 1;
	}

	.chat-header-name {
		font-family: 'Syne',sans-serif;
		font-weight: 700;
		font-size: 15px;
		color: var(--text);
	}

	.chat-header-status {
		font-size: 11px;
		color: #22C55E;
		font-weight: 500;
	}

	.chat-header-actions {
		display: flex;
		gap: 4px;
	}

	/* Messages */
	.messages-area {
		flex: 1;
		overflow-y: auto;
		padding: 20px 24px;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

		.messages-area::-webkit-scrollbar {
			width: 4px;
		}

		.messages-area::-webkit-scrollbar-thumb {
			background: rgba(122,184,0,0.2);
			border-radius: 2px;
		}

	.msg-date-divider {
		text-align: center;
		font-size: 11px;
		color: var(--muted);
		padding: 10px 0;
		display: flex;
		align-items: center;
		gap: 12px;
	}

		.msg-date-divider::before, .msg-date-divider::after {
			content: '';
			flex: 1;
			height: 1px;
			background: var(--border);
		}

	.msg-group {
		margin-bottom: 10px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

		.msg-group.own {
			align-items: flex-end;
		}
	/* base row: received messages */
	.msg-row {
		display: flex;
		gap: 8px;
		align-items: flex-end;
		margin-bottom: 2px;
	}

	.msg-avatar-sm {
		width: 28px;
		height: 28px;
		border-radius: 50%;
		background: linear-gradient(135deg,#4A7C1F,#2D5016);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 13px;
		flex-shrink: 0;
	}

	/* BUBBLES */
	.msg-bubble {
		padding: 10px 14px;
		border-radius: 18px;
		font-size: 14px;
		line-height: 1.55;
		word-break: break-word;
		max-width: 360px;
	}
	/* received */
	.msg-row:not(.own) .msg-bubble {
		background: var(--surface);
		border: 1px solid var(--border);
		border-bottom-left-radius: 5px;
		color: var(--text);
		box-shadow: 0 1px 4px rgba(45,80,22,0.06);
	}
	/* OWN messages */
	.msg-row.own {
		justify-content: flex-end;
	}

		.msg-row.own .msg-avatar-sm {
			display: none;
		}

		.msg-row.own .msg-bubble {
			background: var(--lime);
			color: #1A1F0E;
			border-bottom-right-radius: 5px;
			font-weight: 500;
			box-shadow: 0 2px 8px rgba(122,184,0,0.25);
		}

	/* meta row — sits inside msg-group, inherits align-items:flex-end for own */
	.msg-meta {
		display: flex;
		align-items: center;
		gap: 4px;
		padding: 0 4px;
		margin-top: 2px;
	}

	.msg-time {
		font-size: 10px;
		color: var(--muted);
	}

	.msg-check {
		font-size: 11px;
		color: var(--lime);
	}

	.msg-image-wrap {
		display: inline-block;
		width: 220px;
		border-radius: 14px;
		overflow: hidden;
		margin-bottom: 2px;
		border: 1px solid var(--border);
		box-shadow: 0 1px 4px rgba(45,80,22,0.06);
	}

	.msg-image {
		width: 100%;
		height: 150px;
		background: linear-gradient(135deg,var(--lime-pale),var(--surface3));
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 36px;
	}

	.msg-image-caption {
		padding: 8px 12px;
		background: var(--surface);
		font-size: 13px;
		color: var(--text);
	}

	/* reactions sit flush below the bubble, offset by avatar width only */
	.msg-reactions {
		display: flex;
		gap: 4px;
		margin-top: -6px; /* overlap slightly under bubble */
		margin-left: 36px; /* align with bubble start (after avatar) */
		margin-bottom: 2px;
	}

	.msg-group.own .msg-reactions {
		margin-left: 0;
	}

	.reaction-chip {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 3px 9px;
		font-size: 12px;
		cursor: pointer;
		transition: all 0.2s;
		box-shadow: 0 1px 4px rgba(45,80,22,0.08);
	}

		.reaction-chip:hover {
			background: var(--lime-pale);
			border-color: var(--lime);
			transform: scale(1.08);
		}

	/* Typing */
	.typing-indicator {
		display: flex;
		gap: 8px;
		align-items: center;
		padding: 4px 0;
	}

	.typing-dots {
		background: var(--surface);
		border: 1px solid var(--border);
		padding: 10px 16px;
		border-radius: 18px;
		border-bottom-left-radius: 5px;
		display: flex;
		gap: 4px;
		box-shadow: 0 1px 4px rgba(45,80,22,0.06);
	}

	.dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--lime);
		animation: bounce 1.4s infinite;
		opacity: 0.7;
	}

		.dot:nth-child(2) {
			animation-delay: .2s;
		}

		.dot:nth-child(3) {
			animation-delay: .4s;
		}

	@@keyframes bounce {
		0%, 60%, 100% {
			transform: translateY(0)
		}

		30% {
			transform: translateY(-6px)
		}
	}

	/* Input area */
	.input-area {
		padding: 12px 20px;
		border-top: 1px solid var(--border);
		background: var(--surface);
	}

	.input-toolbar {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 10px 12px;
		background: var(--surface2);
		border: 1.5px solid var(--border);
		border-radius: 16px;
		transition: border-color 0.3s;
	}

		.input-toolbar:focus-within {
			border-color: var(--lime);
			box-shadow: 0 0 0 3px rgba(122,184,0,0.08);
		}

	.input-tool-btn {
		width: 32px;
		height: 32px;
		border-radius: 8px;
		border: none;
		background: transparent;
		color: var(--muted);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s;
		flex-shrink: 0;
	}

		.input-tool-btn:hover {
			background: var(--lime-pale);
			color: var(--lime);
		}

	.msg-input {
		flex: 1;
		border: none;
		background: transparent;
		color: var(--text);
		font-family: 'DM Sans',sans-serif;
		font-size: 14px;
		outline: none;
		resize: none;
		max-height: 120px;
	}

		.msg-input::placeholder {
			color: #BCC4A0;
		}

	.send-btn {
		width: 36px;
		height: 36px;
		background: var(--lime);
		border: none;
		border-radius: 10px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		flex-shrink: 0;
		transition: all 0.2s;
		color: #1A1F0E;
	}

		.send-btn:hover {
			background: var(--lime-bright);
			transform: scale(1.05);
		}

		.send-btn:active {
			transform: scale(0.95);
		}

	/* ===== PROFILE PANEL ===== */
	.profile-panel {
		width: 272px;
		background: var(--surface);
		border-left: 1px solid var(--border);
		display: flex;
		flex-direction: column;
		overflow-y: auto;
		padding: 20px;
	}

		.profile-panel::-webkit-scrollbar {
			width: 3px;
		}

		.profile-panel::-webkit-scrollbar-thumb {
			background: rgba(122,184,0,0.2);
			border-radius: 2px;
		}

	.profile-top {
		text-align: center;
		padding-bottom: 18px;
		border-bottom: 1px solid var(--border);
		margin-bottom: 18px;
	}

	.profile-avatar-lg {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		background: linear-gradient(135deg,var(--lime-light) 0%,var(--lime) 60%,#4A7C1F 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 32px;
		margin: 0 auto 10px;
		border: 3px solid rgba(122,184,0,0.25);
		box-shadow: 0 4px 16px rgba(122,184,0,0.2);
	}

	.profile-name {
		font-family: 'Syne',sans-serif;
		font-weight: 700;
		font-size: 15px;
		color: var(--text);
		margin-bottom: 3px;
	}

	.profile-username {
		font-size: 12px;
		color: var(--muted);
		margin-bottom: 10px;
	}

	.profile-status-badge {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 12px;
		background: rgba(34,197,94,0.1);
		border: 1px solid rgba(34,197,94,0.2);
		border-radius: 20px;
		font-size: 11px;
		color: #16A34A;
	}

	.status-dot-sm {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #22C55E;
	}

	.profile-section {
		margin-bottom: 18px;
	}

	.profile-section-title {
		font-size: 10px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1.5px;
		color: var(--muted);
		margin-bottom: 8px;
	}

	.copy-feature-card {
		background: linear-gradient(135deg,var(--lime-pale),rgba(122,184,0,0.06));
		border: 1px solid rgba(122,184,0,0.25);
		border-radius: 12px;
		padding: 14px;
		margin-bottom: 8px;
	}

	.copy-feature-title {
		font-size: 12px;
		font-weight: 700;
		color: var(--lime);
		margin-bottom: 5px;
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.copy-feature-desc {
		font-size: 11px;
		color: var(--text2);
		line-height: 1.5;
	}

	.profile-action-btn {
		width: 100%;
		padding: 9px 12px;
		background: var(--surface2);
		border: 1px solid var(--border);
		border-radius: 10px;
		color: var(--text2);
		font-size: 13px;
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 10px;
		margin-bottom: 6px;
		transition: all 0.2s;
		font-family: 'DM Sans',sans-serif;
	}

		.profile-action-btn:hover {
			background: var(--lime-pale);
			color: var(--lime);
			border-color: rgba(122,184,0,0.25);
		}

	.shared-media {
		display: grid;
		grid-template-columns: repeat(3,1fr);
		gap: 4px;
	}

	.media-thumb {
		aspect-ratio: 1;
		background: var(--surface2);
		border-radius: 8px;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 18px;
		cursor: pointer;
		transition: opacity 0.2s;
		border: 1px solid var(--border);
		color: var(--text2);
	}

		.media-thumb:hover {
			opacity: 0.75;
		}

		.media-thumb.more {
			font-size: 12px;
			font-weight: 700;
			color: var(--lime);
			background: var(--lime-pale);
		}

		.avatar-ring {
			position: relative;
		}

		.avatar-ring::after {
			content: '';
			position: absolute;
			inset: -3px;              /* controls thickness gap */
			border-radius: 50%;
			border: 2px solid var(--lime);
			pointer-events: none;
		}
</style>

<script>
	function selectChat(item){
	document.querySelectorAll('.chat-item').forEach(i=>i.classList.remove('active'));
	item.classList.add('active');
	}
	function sendMessage(){
	const input=document.getElementById('msgInput');
	const text=input.value.trim();
	if(!text)return;
	const area=document.getElementById('msgArea');
	const typing=area.querySelector('.typing-indicator');
	const group=document.createElement('div');
	group.className='msg-group own';
	group.innerHTML=`
	<div class="msg-row own"><div class="msg-bubble">${esc(text)}</div></div>
	<div class="msg-meta"><span class="msg-time">Just now</span><span class="msg-check">✓</span></div>`;
	area.insertBefore(group,typing);
	input.value='';
	area.scrollTop=area.scrollHeight;
	}
	function handleKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}}
	function esc(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
</script>


@if (showGroupModal)
{
	<div style="position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:100;display:flex;align-items:center;justify-content:center;"
		 @onclick="() => showGroupModal = false">

		<div style="background:#fff;border-radius:20px;padding:24px;width:400px;max-width:92vw;display:flex;flex-direction:column;gap:12px;max-height:80vh;overflow-y:auto;"
			 @onclick:stopPropagation="true">

			<div style="display:flex;align-items:center;justify-content:space-between;">
				<span style="font-family:'Syne',sans-serif;font-weight:700;font-size:17px;">
					New Group
				</span>

				<div class="icon-btn" @onclick="() => showGroupModal = false">
					✕
				</div>
			</div>

			<input class="search-input"
				   style="padding:10px 14px;"
				   placeholder="Group name…"
				   @bind="newGroupName"
				   maxlength="60" />

			<input class="search-input"
				   style="padding:10px 14px;"
				   placeholder="Search users to add…"
				   @oninput="SearchUsersForGroup" />

			@if (groupSearchUsers.Any())
			{
				<div style="display:flex;flex-direction:column;gap:4px;max-height:160px;overflow-y:auto;">
					@foreach (var u in groupSearchUsers)
					{
						<div style="padding:9px 12px;border-radius:10px;cursor:pointer;display:flex;align-items:center;justify-content:space-between;font-size:13px;background:@(selectedParticipantIds.Contains(u.UserId!) ? "var(--lime-pale)" : "transparent")"
							 @onclick="() => ToggleParticipant(u.UserId!, u.DisplayName!)">

							<span>@u.DisplayName</span>

							@if (selectedParticipantIds.Contains(u.UserId!))
							{
								<span style="color:var(--lime)">✓</span>
							}
						</div>
					}
				</div>
			}

			@if (selectedParticipantIds.Any())
			{
				<div style="display:flex;flex-wrap:wrap;gap:6px;">
					@foreach (var id in selectedParticipantIds)
					{
						var name = selectedParticipantNames.GetValueOrDefault(id, id[..4] + "…");

						<span style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:var(--lime-pale);border:1px solid rgba(122,184,0,0.3);border-radius:20px;font-size:12px;font-weight:600;color:var(--lime);">
							@name

							<span style="cursor:pointer;opacity:.6;"
								  @onclick="() => ToggleParticipant(id, name)">
								✕
							</span>
						</span>
					}
				</div>
			}

			<button style="width:100%;padding:11px;background:var(--lime);border:none;border-radius:12px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;color:#1A1F0E;cursor:pointer;opacity:@(CanCreateGroup ? "1" : "0.45")"
					@onclick="CreateGroup"
					disabled="@(CanCreateGroup ? null : "disabled")">

				@(isCreatingGroup ? "Creating…" : "Create Group")
			</button>

		</div>
	</div>
}

<div class="chat-list-panel">
	<div class="panel-header">
		<div class="panel-title">
			Messages
			<div class="header-actions">
				<div class="icon-btn" title="New group" @onclick="OpenGroupModal">
					<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
						<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
						<circle cx="9" cy="7" r="4" />
						<path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" />
					</svg>
				</div>
				<div class="icon-btn" title="Filter">
					<svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M3 4h18M7 8h10M11 12h2" /></svg>
				</div>
			</div>
		</div>
		<div class="search-box">
			<div class="search-icon"><svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg></div>
			<input class="search-input" name="searchConversation" placeholder="Search conversations…" @oninput="HandleSubmit">
		</div>
	</div>

	@* Current Thought bar *@
	<div style="padding:10px 12px;border-top:1px solid var(--border);background:var(--surface2);">
		@if (isEditingThought)
		{
			<div style="display:flex;gap:6px;align-items:center;">
				<input style="flex:1;padding:7px 10px;border:1.5px solid var(--lime);border-radius:10px;background:#fff;font-family:'DM Sans',sans-serif;font-size:12px;color:var(--text);outline:none;"
					   placeholder="What are you thinking…"
					   maxlength="120"
					   @bind="thoughtDraft"
					   @onkeydown="HandleThoughtKey" />
				<div style="width:28px;height:28px;border-radius:8px;background:var(--lime);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;"
					 @onclick="SaveThought">
					<svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="3"><path d="M5 13l4 4L19 7" /></svg>
				</div>
				<div style="width:28px;height:28px;border-radius:8px;background:var(--surface3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;"
					 @onclick="() => isEditingThought = false">
					<svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M6 18L18 6M6 6l12 12" /></svg>
				</div>
			</div>
		}
		else
		{
			<div style="display:flex;align-items:center;gap:8px;cursor:pointer;group"
				 @onclick="OpenThoughtEditor">
				<div style="width:7px;height:7px;border-radius:50%;background:@(string.IsNullOrEmpty(currentThought) ? "var(--muted)" : "var(--lime)");flex-shrink:0;"></div>
				<span style="flex:1;font-size:12px;color:@(string.IsNullOrEmpty(currentThought) ? "var(--muted)" : "var(--text2)");white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-style:@(string.IsNullOrEmpty(currentThought) ? "italic" : "normal");">
					@(string.IsNullOrEmpty(currentThought) ? "Set a current thought…" : currentThought)
				</span>
				<svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--muted);flex-shrink:0;"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
			</div>
		}
	</div>

	<div class="filter-tabs">
		<div class="filter-tab @(activeFilter=="all"?"active":"")"
			 @onclick='()=>activeFilter="all"'>
			All
		</div>
		<div class="filter-tab @(activeFilter=="unread"?"active":"")"
			 @onclick='()=>activeFilter="unread"'>
			Unread
		</div>
		<div class="filter-tab @(activeFilter=="groups"?"active":"")"
			 @onclick='()=>activeFilter="groups"'>
			Groups
		</div>

	</div>
	<div class="chat-list">
		@* Search Users Result *@
		@if (users != null && users.Any())
		{
			<div class="section-label">Users</div>
			@foreach (var user in users)
			{
				<div class="chat-item" @onclick="() => SelectConversation(user)">
                        <div class="chat-avatar">
                            <div class="avatar-img">🥝</div>
                        </div>
					<div class="chat-info">
						<div class="chat-name-row">
							<div class="chat-name">@user.DisplayName</div>
						</div>
					</div>
				</div>
			}
		}

        @* Direct Messages *@
        @{
            var directs = FilteredConversations
            .Where(c => c.Type == ConversationType.Direct && c.LastMessage != null)
            .ToList();
        }
        @if (directs.Any())
        {
            <div class="section-label">Direct Messages</div>
            @foreach (var conv in directs)
            {
                var other = conv.Participants?.FirstOrDefault(p => p.UserId != currentUserId);
                var displayName = other?.DisplayName ?? "Direct Message";

                <div class="chat-item" @onclick="() => SelectConversation(conv)">
                    <div class="chat-avatar">
                        <div class="avatar-img @(NotifState.Contains(conv.ConversationId.ToString().ToLower()) ? "avatar-ring" : "")">
                            🥝
                        </div>
                    </div>
                    <div class="chat-info">
                        <div class="chat-name-row">
                            <div class="chat-name">@displayName</div>
                            @if (conv.LastMessage != null)
                            {
                                <span style="font-size:11px;color:var(--muted);flex-shrink:0;margin-left:6px;white-space:nowrap;">
                                    @FormatConvTime(conv.LastMessage.CreatedAt)
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(conv.LastMessage?.Content))
                        {
                            <div style="font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;
                                            text-overflow:ellipsis;max-width:180px;margin-top:2px;">
                                @conv.LastMessage.Content
                            </div>
                        }
                        else if (conv.LastMessage?.Attachments != null)
                        {
                            <div style="font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;
                                                                    text-overflow:ellipsis;max-width:180px;margin-top:2px; font-style: italic;">
                            📎 Attachment
                            </div>
                        }
                    </div>
                </div>
            }
        }

        @* Groups *@
        @{
            var groups = FilteredConversations.Where(c => c.Type == ConversationType.Group).ToList();
        }
        @if (groups.Any())
        {
            <div class="section-label">Groups</div>
            @foreach (var conv in groups)
            {
                <div class="chat-item" @onclick="() => SelectConversation(conv)">
                    <div class="chat-avatar">
                        <div class="avatar-img @(NotifState.Contains(conv.ConversationId.ToString()) ? "avatar-ring" : "")">
                            🌿
                        </div>
                    </div>
                    <div class="chat-info">
                        <div class="chat-name-row">
                            <div class="chat-name">@conv.GroupName</div>
                            @if (conv.LastMessage != null)
                            {
                                <span style="font-size:11px;color:var(--muted);flex-shrink:0;margin-left:6px;white-space:nowrap;">
                                    @FormatConvTime(conv.LastMessage.CreatedAt)
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(conv.LastMessage?.Content))
                        {
                            <div style="font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;
                                            text-overflow:ellipsis;max-width:180px;margin-top:2px;">
                                @conv.LastMessage.Content
                            </div>
                        }
                    </div>
                </div>
            }
        }
	</div>
</div>

@code {
	private List<UserProfile>? users;
	private List<ConversationDto>? conversations;
	[Parameter] public string? currentUserId { get; set; } = string.Empty;
	private string activeFilter = "all";

	private string _loadedForUserId = "";
	private HubConnection? _navHub;
	private HubConnection? _notifHub;

	protected override void OnInitialized()
	{
		NotifState.OnChange += HandleStateChange;
	}

	private void HandleStateChange()
	{
		InvokeAsync(StateHasChanged);
	}

	protected override async Task OnParametersSetAsync()
	{
		if (string.IsNullOrEmpty(currentUserId)) return;
		if (_loadedForUserId == currentUserId) return;

		_loadedForUserId = currentUserId;
		conversations = await conversationService.GetUserConversationsAsync(currentUserId!);
		currentThought = await CurrentThoughtService.GetThoughtAsync(currentUserId!);
		if (_navHub == null)          
			await StartNavHubAsync();

		StateHasChanged();
	}

	private async Task StartNavHubAsync()
	{
		var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
		var cookieStr = string.Join("; ", cookies?.Select(c => $"{c.Key}={c.Value}") ?? []);

		_navHub = new HubConnectionBuilder()
			.WithUrl(Navigation.ToAbsoluteUri("/chathub"), options =>
			{
				options.Headers.Add("Cookie", cookieStr);
			})
			.WithAutomaticReconnect()
			.Build();
		_navHub.On<string>("GroupNameUpdated", async (newName) =>
		{
			conversations = await conversationService.GetUserConversationsAsync(currentUserId!);
			await InvokeAsync(StateHasChanged);
		});

		_navHub.On("ConversationListChanged", async () =>
		{
			conversations = await conversationService.GetUserConversationsAsync(currentUserId!);
			await InvokeAsync(StateHasChanged);
		});
		_navHub.On<string>("RemovedFromGroup", async (conversationId) =>
		{
		conversations?.RemoveAll(c => c.ConversationId.ToString() == conversationId);
		await InvokeAsync(StateHasChanged);

		if (Navigation.Uri.Contains(conversationId))
			Navigation.NavigateTo("/chat");
		});

		await _navHub.StartAsync(); 
	}

	private IEnumerable<ConversationDto> FilteredConversations => activeFilter switch
	{
		"groups" => conversations?
			.Where(c => c.Type == ConversationType.Group)
			?? Enumerable.Empty<ConversationDto>(),
		_ => conversations ?? Enumerable.Empty<ConversationDto>()
	};

	private async Task HandleSubmit(ChangeEventArgs e)
	{
		var q = e?.Value?.ToString();
		if (!string.IsNullOrEmpty(q))
		{
			conversations = await conversationService.FindGroupConversationsAsync(currentUserId!, q);
			users = userService.GetUsersByDisplayNameAsync(q).ToList();
			StateHasChanged();
		}
		else
		{
			conversations = await conversationService.GetUserConversationsAsync(currentUserId!);
			users = new();
		}
	}

	private async Task SelectConversation(UserProfile user)
	{
		var conv = await conversationService.FindDirectConversationsAsync(currentUserId!, user.UserId);
		NotifState.Remove(conv.ConversationId.ToString().ToLower());
		if (conv != null)
			Navigation.NavigateTo($"/chat/{conv.ConversationId}");
	}

	private void SelectConversation(ConversationDto conv)
	{
		NotifState.Remove(conv.ConversationId.ToString().ToLower());
		Navigation.NavigateTo($"/chat/{conv.ConversationId}");
	}

	private bool showGroupModal;
	private bool isCreatingGroup;
	private string newGroupName = "";
	private List<UserProfile> groupSearchUsers = new();
	private List<string> selectedParticipantIds = new();
	private Dictionary<string, string> selectedParticipantNames = new();
	private bool CanCreateGroup =>
	!string.IsNullOrWhiteSpace(newGroupName)
	&& selectedParticipantIds.Any()
	&& !isCreatingGroup;

	public void OpenGroupModal()
	{
		showGroupModal = true;
		isCreatingGroup = false;
		newGroupName = "";
		groupSearchUsers.Clear();
		selectedParticipantIds.Clear();
		selectedParticipantNames.Clear();
	}

	private async Task SearchUsersForGroup(ChangeEventArgs e)
	{
		var q = e.Value?.ToString() ?? "";
		if (string.IsNullOrEmpty(q) || string.IsNullOrEmpty(currentUserId))
		{
			groupSearchUsers.Clear();
			return;
		}
		groupSearchUsers = userService
			.GetUsersByDisplayNameAsync(q)
			.Where(u => u.AccountStatus == Kotoba.Modules.Domain.Enums.AccountStatus.Active
					&& u.UserId != currentUserId
					&& !selectedParticipantIds.Contains(u.UserId!))
			.Take(7)
			.ToList();
		StateHasChanged();
	}

	public void ToggleParticipant(string userId, string displayName)
	{
		if (selectedParticipantIds.Contains(userId))
		{
			selectedParticipantIds.Remove(userId);
			selectedParticipantNames.Remove(userId);
		}
		else
		{
			selectedParticipantIds.Add(userId);
			selectedParticipantNames[userId] = displayName;
		}
	}

	public async Task CreateGroup()
	{
		if (!CanCreateGroup) return;
		isCreatingGroup = true;
		StateHasChanged();
		try
		{
			var ids = selectedParticipantIds.ToList();
			ids.Add(currentUserId);

			var conv = await conversationService.CreateGroupConversationAsync(new CreateGroupRequest
				{
					GroupName = newGroupName,
					ParticipantIds = ids,
					CreatorId = currentUserId  
				});

			if (conv != null)
			{
				conversations = await conversationService.GetUserConversationsAsync(currentUserId!);
				showGroupModal = false;
				StateHasChanged();
				if (_navHub?.State == HubConnectionState.Connected) await _navHub.InvokeAsync("NotifyGroupCreated", ids);
				Navigation.NavigateTo($"/chat/{conv.ConversationId}");
			}

		}
		catch (Exception e)
		{
			Console.WriteLine(e.Message);
		}
		isCreatingGroup = false;
		StateHasChanged();
	}


	private string? currentThought;
	private string thoughtDraft = "";
	private bool isEditingThought;

	private void OpenThoughtEditor()
	{
		thoughtDraft = currentThought ?? "";
		isEditingThought = true;
	}
	private async Task SaveThought()
	{
		if (string.IsNullOrWhiteSpace(thoughtDraft)) return;
		var trimmed = thoughtDraft.Trim();

		await CurrentThoughtService.SetThoughtAsync(currentUserId!, trimmed);
		if (_navHub?.State == HubConnectionState.Connected)
			await _navHub.InvokeAsync("UpdateThought", trimmed);

		currentThought = trimmed;
		isEditingThought = false;
		StateHasChanged();
	}
	private async Task HandleThoughtKey(KeyboardEventArgs e)
	{
		if (e.Key == "Enter") await SaveThought();
		else if (e.Key == "Escape") isEditingThought = false;
	}

	public async Task ReloadConversations()
	{
		if (string.IsNullOrEmpty(currentUserId)) return;
		conversations = await conversationService.GetUserConversationsAsync(currentUserId!);
		StateHasChanged();
	}

	public async ValueTask DisposeAsync()
	{
		if (_navHub is not null)
			await _navHub.DisposeAsync();

		if (_notifHub is not null)
			await _notifHub.DisposeAsync();

		NotifState.OnChange -= StateHasChanged;
	}
    private static string FormatConvTime(DateTime utcTime)
    {
        var local = utcTime.ToLocalTime();
        var now = DateTime.Now;
        var delta = now - local;

        if (delta.TotalMinutes < 1) return "just now";
        if (delta.TotalHours < 1) return $"{(int)delta.TotalMinutes}m";
        if (delta.TotalDays < 1) return local.ToString("hh:mm tt");
        if (delta.TotalDays < 7) return local.ToString("ddd");
        return local.ToString("dd/MM");
    }

}
