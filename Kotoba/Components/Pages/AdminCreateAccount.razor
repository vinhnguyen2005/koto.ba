@page "/admin/system/admins/create"
@layout Kotoba.Components.Layout.AdminLayout
@using Kotoba.Modules.Domain.Constants
@using Kotoba.Modules.Domain.DTOs
@using Kotoba.Modules.Domain.Enums
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = AdminRoles.SystemAdmin)]
@inject IUserService UserService
@inject IAdminAuditService AdminAuditService
@inject IJSRuntime JsRuntime
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Create Admin Account</PageTitle>

<div class="admin-console">
    <aside class="admin-side">
        <div class="admin-brand">
            <div class="admin-brand-mark">K</div>
            <div>
                <div class="admin-brand-name">koto.ba</div>
                <div class="admin-brand-sub">System Administration</div>
            </div>
        </div>

        <nav class="admin-nav" aria-label="System admin navigation">
            <p class="admin-nav-label">Overview</p>
            <a class="admin-nav-item" href="/admin/system/dashboard">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 13h8V3H3z" />
                        <path d="M13 21h8v-8h-8z" />
                        <path d="M13 3h8v6h-8z" />
                        <path d="M3 21h8v-6H3z" />
                    </svg>
                </span>
                <span>System Overview</span>
            </a>
            <p class="admin-nav-label">Management</p>
            <a class="admin-nav-item active" href="/admin/system/admins/create">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M19 8v6" />
                        <path d="M16 11h6" />
                    </svg>
                </span>
                <span>Admin Accounts</span>
            </a>
            <a class="admin-nav-item" href="/admin/system/audits">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 12h6" />
                        <path d="M9 16h6" />
                        <path d="M9 8h6" />
                        <path d="M4 5h16v14H4z" />
                    </svg>
                </span>
                <span>Audit Trails</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 2l9 4.5V12c0 5-3.4 9.6-9 10-5.6-.4-9-5-9-10V6.5z" />
                        <path d="M9 12l2 2 4-4" />
                    </svg>
                </span>
                <span>Security Alerts</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                        <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.04 1.56V21a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-1.04-1.56 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-1.56-1.04H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.65 8.9a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.7 1.7 0 0 0 1.87.34h.01A1.7 1.7 0 0 0 10 2.98V3a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1.04 1.56h.01a1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.7 1.7 0 0 0-.34 1.87v.01A1.7 1.7 0 0 0 21 10h.09a2 2 0 1 1 0 4H21a1.7 1.7 0 0 0-1.56 1z" />
                    </svg>
                </span>
                <span>Platform Settings</span>
            </a>
        </nav>

        <div class="admin-side-footer">
            <a class="admin-nav-item admin-side-logout" href="/auth/admin/logout">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <path d="M16 17l5-5-5-5" />
                        <path d="M21 12H9" />
                    </svg>
                </span>
                <span>Log out</span>
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <header class="admin-topbar">
            <div>
                <p class="admin-eyebrow">Admin Management</p>
                <h1 class="admin-title">Business Admins</h1>
            </div>
            <div class="admin-pill">System Admin</div>
        </header>

        <section class="admin-stats">
            <article class="admin-stat-card">
                <div class="admin-stat-value">@BusinessAdmins.Count</div>
                <div class="admin-stat-label">Active Business Admin@(BusinessAdmins.Count != 1 ? "s" : "")</div>
            </article>
            <article class="admin-stat-card">
                <div class="admin-stat-value">@AdminsCreatedThisMonth</div>
                <div class="admin-stat-label">New (30 days)</div>
            </article>
            <article class="admin-stat-card">
                <div class="admin-stat-value">@InactiveAdminCount</div>
                <div class="admin-stat-label">Inactive Accounts</div>
            </article>
            <article class="admin-stat-card">
                <div class="admin-stat-value">@ActiveAdminCount</div>
                <div class="admin-stat-label">Active Accounts</div>
            </article>
        </section>

        <section class="admin-panels">
            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">New Admin Account</h2>
                    <span class="admin-panel-badge">Business Admin</span>
                </div>

                @if (Created)
                {
                    <div class="admin-create-alert admin-create-alert-success" role="status">
                        Business admin account created successfully.
                    </div>
                }

                @if (Errors.Count > 0)
                {
                    <div class="admin-create-alert admin-create-alert-error" role="alert">
                        @foreach (var error in Errors)
                        {
                            <div>@error</div>
                        }
                    </div>
                }

                <form method="post" action="/admin/system/admins/create" class="admin-create-form">
                    <AntiforgeryToken />

                    <label class="admin-create-label" for="display-name">Display Name</label>
                    <input id="display-name" name="DisplayName" class="admin-create-input" type="text" maxlength="120" required />

                    <label class="admin-create-label" for="email">Email</label>
                    <input id="email" name="Email" class="admin-create-input" type="email" maxlength="256" required />

                    <label class="admin-create-label" for="password">Temporary Password</label>
                    <input id="password" name="Password" class="admin-create-input" type="password" required />

                    <button type="submit" class="admin-create-submit">Create Business Admin</button>
                </form>
            </article>

            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Recent Admin Creation Audits</h2>
                    <span class="admin-panel-badge">Audit</span>
                </div>

                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Time (UTC)</th>
                                <th>Action By</th>
                                <th>Target</th>
                                <th>Status</th>
                                <th>Summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (RecentCreateAudits.Count == 0)
                            {
                                <tr>
                                    <td colspan="5">No admin creation audit events found yet.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var audit in RecentCreateAudits)
                                {
                                    <tr>
                                        <td>@audit.TimestampUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@FormatActor(audit)</td>
                                        <td>@(string.IsNullOrWhiteSpace(audit.TargetEntityId) ? "-" : audit.TargetEntityId)</td>
                                        <td>
                                            <span class="admin-tag @(audit.IsSuccess ? string.Empty : "admin-tag-warning")">
                                                @(audit.IsSuccess ? "Success" : "Failed")
                                            </span>
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(audit.Summary) ? "-" : audit.Summary)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Existing Business Admin Accounts</h2>
                    <span class="admin-panel-badge">Directory</span>
                </div>

                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Created (UTC)</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (BusinessAdmins.Count == 0)
                            {
                                <tr>
                                    <td colspan="5">No business admin accounts found yet.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var admin in BusinessAdmins)
                                {
                                    <tr>
                                        <td>@admin.DisplayName</td>
                                        <td>@admin.Email</td>
                                        <td>
                                            <span class="admin-tag @(admin.AccountStatus == AccountStatus.Active ? string.Empty : "admin-tag-warning")">
                                                @admin.AccountStatus
                                            </span>
                                        </td>
                                        <td>@admin.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            @if (admin.AccountStatus == AccountStatus.Active)
                                            {
                                                <button class="admin-action-btn admin-action-disable"
                                                        @onclick="() => DisableAdminAccount(admin.UserId)"
                                                        title="Disable this admin account">
                                                    Disable
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="admin-action-disabled">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    </main>
</div>

@code {
    [SupplyParameterFromQuery(Name = "created")]
    public string? CreatedFlag { get; set; }

    [SupplyParameterFromQuery(Name = "errors")]
    public string? EncodedErrors { get; set; }

    private List<BusinessAdminListItem> BusinessAdmins { get; set; } = new();
    private List<AdminAuditViewDto> RecentCreateAudits { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        BusinessAdmins = (await UserService.GetBusinessAdminsAsync()).ToList();

        var recentAudits = await AdminAuditService.GetRecentAuditsAsync(limit: 60);
        RecentCreateAudits = recentAudits
            .Where(audit => audit.ActionType == AdminActionType.AdminCreated)
            .Take(20)
            .ToList();
    }

    private async Task DisableAdminAccount(string adminId)
    {
        if (string.IsNullOrWhiteSpace(adminId))
        {
            return;
        }

        if (!await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to disable this admin account? They will no longer be able to log in."))
        {
            return;
        }

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var performedByAdminId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (string.IsNullOrWhiteSpace(performedByAdminId))
            {
                await JsRuntime.InvokeVoidAsync("alert", "Unable to resolve your admin session.");
                return;
            }

            var result = await UserService.DisableAdminAsync(adminId, performedByAdminId);

            if (result.Succeeded)
            {
                // Reload the admin list to reflect the change
                BusinessAdmins = (await UserService.GetBusinessAdminsAsync()).ToList();

                // Also reload recent audits to show the new disable event
                var recentAudits = await AdminAuditService.GetRecentAuditsAsync(limit: 60);
                RecentCreateAudits = recentAudits
                    .Where(audit => audit.ActionType == AdminActionType.AdminCreated)
                    .Take(20)
                    .ToList();

                await JsRuntime.InvokeVoidAsync("alert", "Admin account has been disabled successfully.");
            }
            else
            {
                var errorMessage = result.Errors.Count > 0
                    ? string.Join("\n", result.Errors)
                    : "Failed to disable admin account. Please try again.";
                await JsRuntime.InvokeVoidAsync("alert", errorMessage);
            }
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }

    private bool Created => string.Equals(CreatedFlag, "1", StringComparison.Ordinal);

    private IReadOnlyList<string> Errors
    {
        get
        {
            if (string.IsNullOrWhiteSpace(EncodedErrors))
            {
                return Array.Empty<string>();
            }

            var decoded = Uri.UnescapeDataString(EncodedErrors);
            return decoded
                .Split("||", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Distinct(StringComparer.Ordinal)
                .ToArray();
        }
    }

    private static string FormatActor(AdminAuditViewDto audit)
    {
        if (!string.IsNullOrWhiteSpace(audit.PerformedByAdminDisplayName))
        {
            return audit.PerformedByAdminDisplayName;
        }

        if (!string.IsNullOrWhiteSpace(audit.PerformedByAdminEmail))
        {
            return audit.PerformedByAdminEmail;
        }

        return audit.PerformedByAdminId;
    }

    private int AdminsCreatedThisMonth => BusinessAdmins.Count(admin =>
        admin.CreatedAt >= DateTime.UtcNow.AddDays(-30));

    private int InactiveAdminCount => BusinessAdmins.Count(admin =>
        admin.AccountStatus != AccountStatus.Active);

    private int ActiveAdminCount => BusinessAdmins.Count(admin =>
        admin.AccountStatus == AccountStatus.Active);
}

