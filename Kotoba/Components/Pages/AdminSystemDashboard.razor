@page "/admin/system/dashboard"
@layout Kotoba.Components.Layout.AdminLayout
@using Kotoba.Modules.Domain.Constants
@using Kotoba.Modules.Domain.DTOs
@attribute [Authorize(Roles = AdminRoles.SystemAdmin)]
@inject IAdminAuditService AdminAuditService

<PageTitle>System Admin Dashboard</PageTitle>

<div class="admin-console">
    <aside class="admin-side">
        <div class="admin-brand">
            <div class="admin-brand-mark">K</div>
            <div>
                <div class="admin-brand-name">koto.ba</div>
                <div class="admin-brand-sub">System Administration</div>
            </div>
        </div>

        <nav class="admin-nav" aria-label="System admin navigation">
            <p class="admin-nav-label">Overview</p>
            <a class="admin-nav-item active" href="/admin/system/dashboard">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 13h8V3H3z" />
                        <path d="M13 21h8v-8h-8z" />
                        <path d="M13 3h8v6h-8z" />
                        <path d="M3 21h8v-6H3z" />
                    </svg>
                </span>
                <span>System Overview</span>
            </a>
            <p class="admin-nav-label">Management</p>
            <a class="admin-nav-item" href="/admin/system/admins/create">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M19 8v6" />
                        <path d="M16 11h6" />
                    </svg>
                </span>
                <span>Admin Accounts</span>
            </a>
            <a class="admin-nav-item" href="/admin/system/audits">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 12h6" />
                        <path d="M9 16h6" />
                        <path d="M9 8h6" />
                        <path d="M4 5h16v14H4z" />
                    </svg>
                </span>
                <span>Audit Trails</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 2l9 4.5V12c0 5-3.4 9.6-9 10-5.6-.4-9-5-9-10V6.5z" />
                        <path d="M9 12l2 2 4-4" />
                    </svg>
                </span>
                <span>Security Alerts</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" />
                        <path d="M19.4 15a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.04 1.56V21a2 2 0 1 1-4 0v-.09a1.7 1.7 0 0 0-1.04-1.56 1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-1.56-1.04H3a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.65 8.9a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.7 1.7 0 0 0 1.87.34h.01A1.7 1.7 0 0 0 10 2.98V3a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1.04 1.56h.01a1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.7 1.7 0 0 0-.34 1.87v.01A1.7 1.7 0 0 0 21 10h.09a2 2 0 1 1 0 4H21a1.7 1.7 0 0 0-1.56 1z" />
                    </svg>
                </span>
                <span>Platform Settings</span>
            </a>
        </nav>

        <div class="admin-side-footer">
            <a class="admin-nav-item admin-side-logout" href="/auth/admin/logout">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <path d="M16 17l5-5-5-5" />
                        <path d="M21 12H9" />
                    </svg>
                </span>
                <span>Log out</span>
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <header class="admin-topbar">
            <div>
                <p class="admin-eyebrow">Root Control</p>
                <h1 class="admin-title">System Admin Dashboard</h1>
            </div>
            <div class="admin-pill">System Admin</div>
        </header>

        <section class="admin-stats" aria-label="System metrics">
            <article class="admin-stat-card">
                <p class="admin-stat-label">Business Admin Accounts</p>
                <p class="admin-stat-value">12</p>
                <p class="admin-stat-meta">2 pending verification</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Audit Events (24h)</p>
                <p class="admin-stat-value">@AuditEventsLast24h</p>
                <p class="admin-stat-meta">Trace coverage: 100%</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Security Alerts</p>
                <p class="admin-stat-value">3</p>
                <p class="admin-stat-meta">1 high priority</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Platform Health</p>
                <p class="admin-stat-value">99.95%</p>
                <p class="admin-stat-meta">All core services online</p>
            </article>
        </section>

        <section class="admin-panels">
            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Admin Provisioning Queue</h2>
                    <span class="admin-panel-badge">System</span>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Email</th>
                                <th>Requested By</th>
                                <th>Status</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>ops-admin@koto.ba</td>
                                <td>root@koto.ba</td>
                                <td><span class="admin-tag">Ready</span></td>
                                <td>2026-03-28 09:42</td>
                            </tr>
                            <tr>
                                <td>risk-admin@koto.ba</td>
                                <td>root@koto.ba</td>
                                <td><span class="admin-tag admin-tag-warning">Pending</span></td>
                                <td>2026-03-28 09:55</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Recent Traceability Events</h2>
                    <span class="admin-panel-badge">Audit</span>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Time (UTC)</th>
                                <th>Admin</th>
                                <th>Action</th>
                                <th>Target</th>
                                <th>Status</th>
                                <th>Summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (RecentAudits.Count == 0)
                            {
                                <tr>
                                    <td colspan="6">No audit entries yet.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var audit in RecentAudits)
                                {
                                    <tr>
                                        <td>@audit.TimestampUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@FormatActor(audit)</td>
                                        <td>@audit.ActionType</td>
                                        <td>@FormatTarget(audit)</td>
                                        <td>
                                            <span class="admin-tag @(audit.IsSuccess ? string.Empty : "admin-tag-warning")">
                                                @(audit.IsSuccess ? "Success" : "Failed")
                                            </span>
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(audit.Summary) ? "-" : audit.Summary)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    </main>
</div>

@code {
    private int AuditEventsLast24h;
    private List<AdminAuditViewDto> RecentAudits { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var sinceUtc = DateTime.UtcNow.AddHours(-24);
        AuditEventsLast24h = await AdminAuditService.CountAuditsSinceAsync(sinceUtc);
        RecentAudits = (await AdminAuditService.GetRecentAuditsAsync(limit: 20)).ToList();
    }

    private static string FormatActor(AdminAuditViewDto audit)
    {
        if (!string.IsNullOrWhiteSpace(audit.PerformedByAdminDisplayName))
        {
            return audit.PerformedByAdminDisplayName;
        }

        if (!string.IsNullOrWhiteSpace(audit.PerformedByAdminEmail))
        {
            return audit.PerformedByAdminEmail;
        }

        return audit.PerformedByAdminId;
    }

    private static string FormatTarget(AdminAuditViewDto audit)
    {
        if (string.IsNullOrWhiteSpace(audit.TargetEntityType) && string.IsNullOrWhiteSpace(audit.TargetEntityId))
        {
            return "-";
        }

        if (string.IsNullOrWhiteSpace(audit.TargetEntityType))
        {
            return audit.TargetEntityId ?? "-";
        }

        if (string.IsNullOrWhiteSpace(audit.TargetEntityId))
        {
            return audit.TargetEntityType;
        }

        return $"{audit.TargetEntityType}:{audit.TargetEntityId}";
    }
}
