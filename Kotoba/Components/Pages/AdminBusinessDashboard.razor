@page "/admin/business/dashboard"
@layout Kotoba.Components.Layout.AdminLayout
@using Kotoba.Modules.Domain.Constants
@using Kotoba.Modules.Domain.DTOs
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = AdminRoles.BusinessAdmin)]
@inject IAdminAuditService AdminAuditService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Business Admin Dashboard</PageTitle>

<div class="admin-console">
    <aside class="admin-side">
        <div class="admin-brand">
            <div class="admin-brand-mark">K</div>
            <div>
                <div class="admin-brand-name">koto.ba</div>
                <div class="admin-brand-sub">Business Operations</div>
            </div>
        </div>

        <nav class="admin-nav" aria-label="Business admin navigation">
            <p class="admin-nav-label">Overview</p>
            <a class="admin-nav-item active" href="/admin/business/dashboard">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 13h8V3H3z" />
                        <path d="M13 21h8v-8h-8z" />
                        <path d="M13 3h8v6h-8z" />
                        <path d="M3 21h8v-6H3z" />
                    </svg>
                </span>
                <span>Business Overview</span>
            </a>
            <p class="admin-nav-label">Operations</p>
            <a class="admin-nav-item" href="/admin/business/users">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                </span>
                <span>Users</span>
            </a>
            <a class="admin-nav-item" href="/admin/business/audits">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 12h6" />
                        <path d="M9 16h6" />
                        <path d="M9 8h6" />
                        <path d="M4 5h16v14H4z" />
                    </svg>
                </span>
                <span>Audit Trails</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 9v2" />
                        <path d="M12 17h.01" />
                        <path d="M10.29 3.86l-8.2 14.2A2 2 0 0 0 3.8 21h16.4a2 2 0 0 0 1.73-2.94l-8.2-14.2a2 2 0 0 0-3.44 0z" />
                    </svg>
                </span>
                <span>Reports</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="3" y="3" width="18" height="18" rx="2" />
                        <path d="M3 15h18" />
                        <path d="M9 9h.01" />
                        <path d="M15 9h.01" />
                    </svg>
                </span>
                <span>Stories</span>
            </a>
            <a class="admin-nav-item" href="#">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4 19h16" />
                        <path d="M7 16V9" />
                        <path d="M12 16V5" />
                        <path d="M17 16v-3" />
                    </svg>
                </span>
                <span>Statistics</span>
            </a>
        </nav>

        <div class="admin-side-footer">
            <a class="admin-nav-item admin-side-logout" href="/auth/admin/logout">
                <span class="admin-nav-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <path d="M16 17l5-5-5-5" />
                        <path d="M21 12H9" />
                    </svg>
                </span>
                <span>Log out</span>
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <header class="admin-topbar">
            <div>
                <p class="admin-eyebrow">Operations</p>
                <h1 class="admin-title">Business Admin Dashboard</h1>
            </div>
            <div class="admin-pill">Business Admin</div>
        </header>

        <section class="admin-stats" aria-label="Business metrics">
            <article class="admin-stat-card">
                <p class="admin-stat-label">Active Users</p>
                <p class="admin-stat-value">24,831</p>
                <p class="admin-stat-meta">+2.1% from yesterday</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Open Reports</p>
                <p class="admin-stat-value">11</p>
                <p class="admin-stat-meta">4 high-priority items</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Stories Pending Review</p>
                <p class="admin-stat-value">7</p>
                <p class="admin-stat-meta">2 escalated</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Your Audit Events (24h)</p>
                <p class="admin-stat-value">@MyAuditEventsLast24h</p>
                <p class="admin-stat-meta">Visibility scoped to your account</p>
            </article>
        </section>

        <section class="admin-panels">
            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Report Moderation Queue</h2>
                    <span class="admin-panel-badge">Business</span>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Report ID</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Assigned To</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>RPT-10932</td>
                                <td>Chat abuse</td>
                                <td><span class="admin-tag admin-tag-warning">In Review</span></td>
                                <td>business-admin-3</td>
                            </tr>
                            <tr>
                                <td>RPT-10941</td>
                                <td>Story violation</td>
                                <td><span class="admin-tag">Queued</span></td>
                                <td>business-admin-2</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Your Recent Audit Events</h2>
                    <span class="admin-panel-badge">Activity</span>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Time (UTC)</th>
                                <th>Action</th>
                                <th>Target</th>
                                <th>Status</th>
                                <th>Summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (MyRecentAudits.Count == 0)
                            {
                                <tr>
                                    <td colspan="5">No audit entries yet for your account.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var audit in MyRecentAudits)
                                {
                                    <tr>
                                        <td>@audit.TimestampUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@audit.ActionType</td>
                                        <td>@FormatTarget(audit)</td>
                                        <td>
                                            <span class="admin-tag @(audit.IsSuccess ? string.Empty : "admin-tag-warning")">
                                                @(audit.IsSuccess ? "Success" : "Failed")
                                            </span>
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(audit.Summary) ? "-" : audit.Summary)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    </main>
</div>

@code {
    private int MyAuditEventsLast24h;
    private List<AdminAuditViewDto> MyRecentAudits { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var adminId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrWhiteSpace(adminId))
        {
            return;
        }

        var sinceUtc = DateTime.UtcNow.AddHours(-24);
        MyAuditEventsLast24h = await AdminAuditService.CountAuditsSinceAsync(sinceUtc, adminId);
        MyRecentAudits = (await AdminAuditService.GetRecentAuditsAsync(adminId, 20)).ToList();
    }

    private static string FormatTarget(AdminAuditViewDto audit)
    {
        if (string.IsNullOrWhiteSpace(audit.TargetEntityType) && string.IsNullOrWhiteSpace(audit.TargetEntityId))
        {
            return "-";
        }

        if (string.IsNullOrWhiteSpace(audit.TargetEntityType))
        {
            return audit.TargetEntityId ?? "-";
        }

        if (string.IsNullOrWhiteSpace(audit.TargetEntityId))
        {
            return audit.TargetEntityType;
        }

        return $"{audit.TargetEntityType}:{audit.TargetEntityId}";
    }
}
