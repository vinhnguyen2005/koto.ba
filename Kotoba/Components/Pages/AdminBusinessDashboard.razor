@page "/admin/business/dashboard"
@layout Kotoba.Components.Layout.AdminLayout
@using Kotoba.Modules.Domain.Constants
@using Kotoba.Modules.Domain.DTOs
@using Kotoba.Modules.Domain.Enums
@using Kotoba.Modules.Domain.Interfaces
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = AdminRoles.BusinessAdmin)]
@inject IAdminAuditService AdminAuditService
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IReportService ReportService

<PageTitle>Business Admin Dashboard</PageTitle>

<div class="admin-console">
    <AdminSidebar IsSystemAdmin="false" ActiveItem="AdminSidebarItem.BusinessDashboard" />

    <main class="admin-main">
        <header class="admin-topbar">
            <div>
                <p class="admin-eyebrow">Operations</p>
                <h1 class="admin-title">Business Admin Dashboard</h1>
            </div>
            <div class="admin-pill">Business Admin</div>
        </header>

        <section class="admin-stats" aria-label="Business metrics">
            <article class="admin-stat-card">
                <p class="admin-stat-label">Active Users</p>
                <p class="admin-stat-value">@ActiveUserCount</p>
                <p class="admin-stat-meta">@OnlineUserCount currently online</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Open Reports</p>
                <p class="admin-stat-value">@OpenReportCount</p>
                <p class="admin-stat-meta">@DismissedReportCount dismissed so far</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Stories Pending Review</p>
                <p class="admin-stat-value">@StoryReportsPendingCount</p>
                <p class="admin-stat-meta">@ReviewedStoryReportsCount reviewed</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Your Audit Events (24h)</p>
                <p class="admin-stat-value">@MyAuditEventsLast24h</p>
                <p class="admin-stat-meta">Visibility scoped to your account</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Total Users</p>
                <p class="admin-stat-value">@TotalUserCount</p>
                <p class="admin-stat-meta">Non-admin accounts</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Restricted Accounts</p>
                <p class="admin-stat-value">@RestrictedAccountCount</p>
                <p class="admin-stat-meta">@BannedUserCount banned, @DeactivatedUserCount deactivated</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">New Reports (24h)</p>
                <p class="admin-stat-value">@ReportsCreatedLast24h</p>
                <p class="admin-stat-meta">Incoming moderation workload</p>
            </article>
            <article class="admin-stat-card">
                <p class="admin-stat-label">Queue Resolution</p>
                <p class="admin-stat-value">@ResolutionRateText</p>
                <p class="admin-stat-meta">@ResolvedReportCount resolved / @TotalReportCount total</p>
            </article>
        </section>

        <section class="admin-panels">
            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Report Moderation Queue</h2>
                    <span class="admin-panel-badge">Business</span>
                    <a class="admin-action-btn" href="/admin/business/reports">Open Full Queue</a>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Report ID</th>
                                <th>Target</th>
                                <th>Status</th>
                                <th>Reporter</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (QueuePreview.Count == 0)
                            {
                                <tr>
                                    <td colspan="5">No reports in queue. <a href="/admin/business/reports">Go to reports page</a>.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var report in QueuePreview)
                                {
                                    <tr>
                                        <td>@report.ReportId.ToString()[..8]</td>
                                        <td>@FormatReportTargetPreview(report)</td>
                                        <td>
                                            <span class="admin-tag @GetReportStatusClass(report.Status)">@report.Status</span>
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(report.ReporterDisplayName) ? report.ReporterEmail : report.ReporterDisplayName)</td>
                                        <td><a class="admin-action-btn" href="/admin/business/reports">Open</a></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="admin-panel">
                <div class="admin-panel-header">
                    <h2 class="admin-panel-title">Your Recent Audit Events</h2>
                    <span class="admin-panel-badge">Activity</span>
                </div>
                <div class="admin-table-wrap">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Time (UTC)</th>
                                <th>Action</th>
                                <th>Target</th>
                                <th>Status</th>
                                <th>Summary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (MyRecentAudits.Count == 0)
                            {
                                <tr>
                                    <td colspan="5">No audit entries yet for your account.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var audit in MyRecentAudits)
                                {
                                    <tr>
                                        <td>@audit.TimestampUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@audit.ActionType</td>
                                        <td>@FormatTarget(audit)</td>
                                        <td>
                                            <span class="admin-tag @(audit.IsSuccess ? string.Empty : "admin-tag-warning")">
                                                @(audit.IsSuccess ? "Success" : "Failed")
                                            </span>
                                        </td>
                                        <td>@(string.IsNullOrWhiteSpace(audit.Summary) ? "-" : audit.Summary)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    </main>
</div>

@code {
    private int MyAuditEventsLast24h;
    private int ActiveUserCount;
    private int OnlineUserCount;
    private int OpenReportCount;
    private int DismissedReportCount;
    private int StoryReportsPendingCount;
    private int ReviewedStoryReportsCount;
    private int TotalUserCount;
    private int BannedUserCount;
    private int DeactivatedUserCount;
    private int RestrictedAccountCount;
    private int ReportsCreatedLast24h;
    private int ResolvedReportCount;
    private int TotalReportCount;
    private string ResolutionRateText { get; set; } = "0%";
    private List<AdminReportListItemDto> QueuePreview { get; set; } = new();
    private List<AdminAuditViewDto> MyRecentAudits { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadHeroStatsAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var adminId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrWhiteSpace(adminId))
        {
            return;
        }

        var sinceUtc = DateTime.UtcNow.AddHours(-24);
        MyAuditEventsLast24h = await AdminAuditService.CountAuditsSinceAsync(sinceUtc, adminId);
        MyRecentAudits = (await AdminAuditService.GetRecentAuditsAsync(adminId, 20)).ToList();
    }

    private async Task LoadHeroStatsAsync()
    {
        var usersTask = UserService.GetNormalUsersAsync();
        var reportsTask = ReportService.GetReportsForReviewAsync();

        await Task.WhenAll(usersTask, reportsTask);

        var users = usersTask.Result;
        var reports = reportsTask.Result;

        TotalUserCount = users.Count;
        ActiveUserCount = users.Count(user => user.AccountStatus == AccountStatus.Active);
        BannedUserCount = users.Count(user => user.AccountStatus == AccountStatus.Banned);
        DeactivatedUserCount = users.Count(user => user.AccountStatus == AccountStatus.Deactivated);
        RestrictedAccountCount = BannedUserCount + DeactivatedUserCount;
        OnlineUserCount = users.Count(user => user.IsOnline);

        OpenReportCount = reports.Count(report => report.Status == ReportStatus.Pending);
        DismissedReportCount = reports.Count(report => report.Status == ReportStatus.Dismissed);

        ReportsCreatedLast24h = reports.Count(report => report.CreatedAt >= DateTime.UtcNow.AddHours(-24));
        ResolvedReportCount = reports.Count(report => report.Status is ReportStatus.Reviewed or ReportStatus.Dismissed);
        TotalReportCount = reports.Count;
        ResolutionRateText = TotalReportCount == 0
            ? "0%"
            : $"{Math.Round((double)ResolvedReportCount * 100 / TotalReportCount, MidpointRounding.AwayFromZero)}%";

        StoryReportsPendingCount = reports.Count(report =>
            report.TargetType == ReportTargetType.Story
            && report.Status == ReportStatus.Pending);

        ReviewedStoryReportsCount = reports.Count(report =>
            report.TargetType == ReportTargetType.Story
            && report.Status == ReportStatus.Reviewed);

        QueuePreview = reports
            .Where(report => report.Status == ReportStatus.Pending)
            .OrderByDescending(report => report.CreatedAt)
            .Take(5)
            .ToList();
    }

    private static string FormatReportTargetPreview(AdminReportListItemDto report)
    {
        var preview = string.IsNullOrWhiteSpace(report.TargetPreview) ? "No preview" : report.TargetPreview;
        if (preview.Length > 80)
        {
            preview = preview[..80] + "...";
        }

        return $"{report.TargetType}: {preview}";
    }

    private static string GetReportStatusClass(ReportStatus status)
    {
        return status switch
        {
            ReportStatus.Pending => "admin-tag-warning",
            ReportStatus.Dismissed => string.Empty,
            ReportStatus.Reviewed => string.Empty,
            _ => string.Empty,
        };
    }

    private static string FormatTarget(AdminAuditViewDto audit)
    {
        if (string.IsNullOrWhiteSpace(audit.TargetEntityType) && string.IsNullOrWhiteSpace(audit.TargetEntityId))
        {
            return "-";
        }

        if (string.IsNullOrWhiteSpace(audit.TargetEntityType))
        {
            return audit.TargetEntityId ?? "-";
        }

        if (string.IsNullOrWhiteSpace(audit.TargetEntityId))
        {
            return audit.TargetEntityType;
        }

        return $"{audit.TargetEntityType}:{audit.TargetEntityId}";
    }
}
