@using Kotoba.Modules.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject GlobalNotificationState NotifState
@using Kotoba.Modules.Infrastructure.Services.Notifications

@foreach (var toast in toasts)
{
    <div style="position:fixed;bottom:@(24 + toasts.IndexOf(toast) * 80)px;right:24px;
                    z-index:9999;min-width:300px;max-width:360px;
                    background:#fff;border-radius:14px;
                    box-shadow:0 8px 32px rgba(0,0,0,0.14);
                    border:1px solid var(--border);
                    display:flex;align-items:center;gap:12px;padding:12px 16px;
                    animation:slideInRight 0.3s ease;">
        <div style="font-size:22px;flex-shrink:0;">
            @GetIcon(toast.Type)
        </div>
        <div style="flex:1;min-width:0;">
            <div style="font-size:13px;font-weight:600;color:var(--text);
                            white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                @toast.Message
            </div>
            <div style="font-size:11px;color:var(--muted);margin-top:2px;">
                just now
            </div>
        </div>
        <div style="cursor:pointer;color:var(--muted);flex-shrink:0;"
             @onclick="() => Dismiss(toast)">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5">
                <path d="M6 18L18 6M6 6l12 12" />
            </svg>
        </div>
    </div>
}

<style>
    @@keyframes slideInRight {
        from {
            transform: translateX(120%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

@code {
    [Parameter] public string? UserId { get; set; }

    private List<NotificationDto> toasts = new();
    private HubConnection? _hub;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(UserId) || _hub != null) return;
        await StartHubAsync();
    }

    private async Task StartHubAsync()
    {
        var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
        var cookieStr = string.Join("; ", cookies?.Select(c => $"{c.Key}={c.Value}") ?? []);

        _hub = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/notificationhub"), options =>
            {
                options.Headers.Add("Cookie", cookieStr);
            })
            .WithAutomaticReconnect()
            .Build();

        _hub.On<NotificationDto>("ReceiveNotification", async (dto) =>
        {
            if (dto.Type == NotificationType.NewMessage)
                return;
            NotifState.Increment();
            Console.WriteLine("[Toast] Received notification");

            if (Navigation.Uri.Contains("/notifications")) return;
            
            await InvokeAsync(async () =>
            {
                toasts.Add(dto);
                StateHasChanged();

                await Task.Delay(5000);
                Dismiss(dto);
            });
        });

        await _hub.StartAsync();
        await _hub.InvokeAsync("Register", UserId);
    }

    private void Dismiss(NotificationDto dto)
    {
        toasts.Remove(dto);
        InvokeAsync(StateHasChanged);
    }

    private static string GetIcon(NotificationType type) => type switch
    {
        NotificationType.NewFollower => "👤",
        NotificationType.StoryReaction => "❤️",
        NotificationType.AdminWarning => "⚠️",
        NotificationType.AdminReportAlert => "🚩",
        _ => "🔔"
    };

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null) await _hub.DisposeAsync();
    }
}
